index 0000000000000000000000000000000000000000..2d7bc85b5e9a9907cddb83770eaa8163cfe5880e
--- /dev/null
+++ b/net/minecraft/server/level/FandChunkStepScheduler.java
@@ -0,0 +1,294 @@
+package net.minecraft.server.level;
+
+import it.unimi.dsi.fastutil.longs.Long2IntOpenHashMap;
+import java.util.ArrayDeque;
+import java.util.ArrayList;
+import java.util.List;
+import java.util.concurrent.CompletableFuture;
+import java.util.concurrent.Executor;
+import java.util.function.Supplier;
+import net.minecraft.world.level.ChunkPos;
+import org.jspecify.annotations.Nullable;
+
+public final class FandChunkStepScheduler implements AutoCloseable {
+    private final Executor executor;
+    private final int maxActiveTasks;
+    private final ArrayDeque<FandChunkStepScheduler.ScheduledStep<?>> pendingNarrow = new ArrayDeque<>();
+    private final ArrayDeque<FandChunkStepScheduler.ScheduledStep<?>> pendingWide = new ArrayDeque<>();
+    private final Long2IntOpenHashMap lockedChunks = new Long2IntOpenHashMap();
+    private int activeTasks;
+    private boolean pollWideFirst;
+    private boolean closed;
+
+    FandChunkStepScheduler(final Executor executor, final int maxActiveTasks) {
+        this.executor = executor;
+        this.maxActiveTasks = Math.max(1, maxActiveTasks);
+    }
+
+    public <T> CompletableFuture<T> schedule(
+        final ChunkPos center,
+        final int writeRadius,
+        final Supplier<CompletableFuture<T>> action
+    ) {
+        CompletableFuture<T> result = new CompletableFuture<>();
+        int radius = Math.max(0, writeRadius);
+        FandChunkStepScheduler.ScheduledStep<T> step = new FandChunkStepScheduler.ScheduledStep<>(
+            center,
+            radius,
+            action,
+            result
+        );
+        boolean executeNow;
+
+        synchronized (this) {
+            if (this.closed) {
+                result.completeExceptionally(new IllegalStateException("Chunk step scheduler is closed"));
+                return result;
+            }
+
+            executeNow = this.tryStart(step);
+            if (!executeNow) {
+                this.pendingQueue(step).addLast(step);
+            }
+        }
+
+        if (executeNow) {
+            this.execute(step);
+        } else {
+            this.drain();
+        }
+        return result;
+    }
+
+    private void drain() {
+        List<FandChunkStepScheduler.ScheduledStep<?>> ready = new ArrayList<>();
+
+        synchronized (this) {
+            if (this.closed) {
+                return;
+            }
+
+            while (this.activeTasks < this.maxActiveTasks) {
+                FandChunkStepScheduler.ScheduledStep<?> step = this.pollNextReadyStep();
+
+                if (step == null) {
+                    break;
+                }
+
+                this.start(step);
+                ready.add(step);
+            }
+        }
+
+        for (FandChunkStepScheduler.ScheduledStep<?> step : ready) {
+            this.execute(step);
+        }
+    }
+
+    private FandChunkStepScheduler.@Nullable ScheduledStep<?> pollNextReadyStep() {
+        FandChunkStepScheduler.ScheduledStep<?> step;
+        if (this.pollWideFirst) {
+            step = this.pollReadyStep(this.pendingWide);
+            if (step == null) {
+                step = this.pollReadyStep(this.pendingNarrow);
+            }
+        } else {
+            step = this.pollReadyStep(this.pendingNarrow);
+            if (step == null) {
+                step = this.pollReadyStep(this.pendingWide);
+            }
+        }
+
+        if (step != null) {
+            this.pollWideFirst = !step.isWide();
+        }
+
+        return step;
+    }
+
+    private void execute(final FandChunkStepScheduler.ScheduledStep<?> step) {
+        try {
+            this.executor.execute(() -> this.runStep(step));
+        } catch (Throwable throwable) {
+            this.completeExceptionally(step, throwable);
+        }
+    }
+
+    private <T> void runStep(final FandChunkStepScheduler.ScheduledStep<T> step) {
+        CompletableFuture<T> future;
+        try {
+            future = step.action().get();
+            if (future == null) {
+                throw new IllegalStateException("Chunk step action returned null future");
+            }
+        } catch (Throwable throwable) {
+            this.completeExceptionally(step, throwable);
+            return;
+        }
+
+        future.whenComplete((value, throwable) -> {
+            if (throwable != null) {
+                step.result().completeExceptionally(throwable);
+            } else {
+                step.result().complete(value);
+            }
+
+            this.finish(step);
+        });
+    }
+
+    private void completeExceptionally(final FandChunkStepScheduler.ScheduledStep<?> step, final Throwable throwable) {
+        step.result().completeExceptionally(throwable);
+        this.finish(step);
+    }
+
+    private void finish(final FandChunkStepScheduler.ScheduledStep<?> step) {
+        synchronized (this) {
+            this.unlock(step);
+            this.activeTasks--;
+        }
+
+        this.drain();
+    }
+
+    private ArrayDeque<FandChunkStepScheduler.ScheduledStep<?>> pendingQueue(final FandChunkStepScheduler.ScheduledStep<?> step) {
+        return step.isWide() ? this.pendingWide : this.pendingNarrow;
+    }
+
+    private FandChunkStepScheduler.ScheduledStep<?> pollReadyStep(final ArrayDeque<FandChunkStepScheduler.ScheduledStep<?>> queue) {
+        int attempts = queue.size();
+        while (attempts-- > 0) {
+            FandChunkStepScheduler.ScheduledStep<?> step = queue.pollFirst();
+            if (step == null) {
+                return null;
+            }
+
+            if (!this.canLock(step)) {
+                queue.addLast(step);
+                continue;
+            }
+
+            return step;
+        }
+
+        return null;
+    }
+
+    private boolean canLock(final FandChunkStepScheduler.ScheduledStep<?> step) {
+        if (!step.isWide()) {
+            return true;
+        }
+
+        int centerX = step.center().x();
+        int centerZ = step.center().z();
+        int radius = step.writeRadius();
+        for (int x = centerX - radius; x <= centerX + radius; x++) {
+            for (int z = centerZ - radius; z <= centerZ + radius; z++) {
+                if (this.lockedChunks.containsKey(ChunkPos.pack(x, z))) {
+                    return false;
+                }
+            }
+        }
+
+        return true;
+    }
+
+    private boolean tryStart(final FandChunkStepScheduler.ScheduledStep<?> step) {
+        if (this.activeTasks >= this.maxActiveTasks || !this.canLock(step) || this.hasOlderReadyWork()) {
+            return false;
+        }
+
+        this.start(step);
+        return true;
+    }
+
+    private boolean hasOlderReadyWork() {
+        return this.hasReadyStep(this.pendingNarrow) || this.hasReadyStep(this.pendingWide);
+    }
+
+    private boolean hasReadyStep(final ArrayDeque<FandChunkStepScheduler.ScheduledStep<?>> queue) {
+        for (FandChunkStepScheduler.ScheduledStep<?> pendingStep : queue) {
+            if (this.canLock(pendingStep)) {
+                return true;
+            }
+        }
+
+        return false;
+    }
+
+    private void start(final FandChunkStepScheduler.ScheduledStep<?> step) {
+        this.lock(step);
+        this.activeTasks++;
+    }
+
+    private void lock(final FandChunkStepScheduler.ScheduledStep<?> step) {
+        if (!step.isWide()) {
+            return;
+        }
+
+        int centerX = step.center().x();
+        int centerZ = step.center().z();
+        int radius = step.writeRadius();
+        for (int x = centerX - radius; x <= centerX + radius; x++) {
+            for (int z = centerZ - radius; z <= centerZ + radius; z++) {
+                this.lockedChunks.addTo(ChunkPos.pack(x, z), 1);
+            }
+        }
+    }
+
+    private void unlock(final FandChunkStepScheduler.ScheduledStep<?> step) {
+        if (!step.isWide()) {
+            return;
+        }
+
+        int centerX = step.center().x();
+        int centerZ = step.center().z();
+        int radius = step.writeRadius();
+        for (int x = centerX - radius; x <= centerX + radius; x++) {
+            for (int z = centerZ - radius; z <= centerZ + radius; z++) {
+                this.unlock(ChunkPos.pack(x, z));
+            }
+        }
+    }
+
+    private void unlock(final long chunkPos) {
+        int count = this.lockedChunks.get(chunkPos);
+        if (count <= 0) {
+            throw new IllegalStateException("Chunk step lock underflow for " + ChunkPos.unpack(chunkPos));
+        }
+
+        if (count == 1) {
+            this.lockedChunks.remove(chunkPos);
+        } else {
+            this.lockedChunks.put(chunkPos, count - 1);
+        }
+    }
+
+    @Override
+    public void close() {
+        List<FandChunkStepScheduler.ScheduledStep<?>> cancelled;
+        synchronized (this) {
+            this.closed = true;
+            cancelled = new ArrayList<>(this.pendingNarrow.size() + this.pendingWide.size());
+            cancelled.addAll(this.pendingNarrow);
+            cancelled.addAll(this.pendingWide);
+            this.pendingNarrow.clear();
+            this.pendingWide.clear();
+        }
+
+        for (FandChunkStepScheduler.ScheduledStep<?> step : cancelled) {
+            step.result().completeExceptionally(new IllegalStateException("Chunk step scheduler is closed"));
+        }
+    }
+
+    private record ScheduledStep<T>(
+        ChunkPos center,
+        int writeRadius,
+        Supplier<CompletableFuture<T>> action,
+        CompletableFuture<T> result
+    ) {
+        private boolean isWide() {
+            return this.writeRadius > 0;
+        }
+    }
+}
