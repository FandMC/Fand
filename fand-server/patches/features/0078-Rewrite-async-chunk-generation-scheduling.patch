+    private final class DependencyFanIn implements BiConsumer<ChunkResult<ChunkAccess>, Throwable> {
+        private final GenerationChunkHolder chunkHolder;
+        private final ChunkStatus status;
+        private final ChunkGenerationTask.StepPlan stepPlan;
+        private final CompletableFuture<ChunkResult<ChunkAccess>> result = new CompletableFuture<>();
+        private final AtomicInteger remaining;
+
+        private DependencyFanIn(
+            final GenerationChunkHolder chunkHolder,
+            final ChunkStatus status,
+            final ChunkGenerationTask.StepPlan stepPlan,
+            final int dependencyCount
+        ) {
+            this.chunkHolder = chunkHolder;
+            this.status = status;
+            this.stepPlan = stepPlan;
+            this.remaining = new AtomicInteger(dependencyCount);
+        }
+
+        @Override
+        public void accept(final ChunkResult<ChunkAccess> dependencyResult, final Throwable throwable) {
+            if (this.result.isDone()) {
+                return;
+            }
+
+            if (throwable != null) {
+                this.result.completeExceptionally(throwable);
+                return;
+            }
+
+            if (!dependencyResult.isSuccess()) {
+                this.chunkHolder.failGenerationStatus(this.status, dependencyResult);
+                this.result.complete(dependencyResult);
+                return;
+            }
+
+            if (this.remaining.decrementAndGet() == 0) {
+                ChunkGenerationTask.this.completeAfterDependencies(this.chunkHolder, this.stepPlan, this.result);
+            }
+        }
+
+        private boolean isDone() {
+            return this.result.isDone();
+        }
+
+        private CompletableFuture<ChunkResult<ChunkAccess>> result() {
+            return this.result;
+        }
+    }
+
+    private static ChunkGenerationTask.Dependency[] buildDependencies(final ChunkDependencies dependencies) {
+        if (dependencies.size() == 0) {
+            return new ChunkGenerationTask.Dependency[0];
+        }
+
+        int radius = dependencies.getRadius();
+        ArrayList<ChunkGenerationTask.Dependency> result = new ArrayList<>((radius * 2 + 1) * (radius * 2 + 1));
+        result.add(new ChunkGenerationTask.Dependency(0, 0, dependencies.get(0)));
+        for (int offsetX = -radius; offsetX <= radius; offsetX++) {
+            for (int offsetZ = -radius; offsetZ <= radius; offsetZ++) {
+                if (offsetX == 0 && offsetZ == 0) {
+                    continue;
+                }
+
+                int distance = Math.max(Math.abs(offsetX), Math.abs(offsetZ));
+                result.add(new ChunkGenerationTask.Dependency(offsetX, offsetZ, dependencies.get(distance)));
+            }
+        }
+
+        return result.toArray(ChunkGenerationTask.Dependency[]::new);
+    }
