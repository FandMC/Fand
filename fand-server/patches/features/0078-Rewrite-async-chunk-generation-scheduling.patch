@@ -0,0 +1,58 @@
+package net.minecraft.server.level;
+
+import java.util.concurrent.atomic.AtomicInteger;
+
+final class FandAsyncTaskState {
+    private static final int IDLE = 0;
+    private static final int QUEUED = 1;
+    private static final int RUNNING = 2;
+    private static final int RUNNING_QUEUED = 3;
+
+    private final AtomicInteger state = new AtomicInteger(IDLE);
+
+    boolean markQueued() {
+        while (true) {
+            int current = this.state.get();
+            switch (current) {
+                case IDLE:
+                    if (this.state.compareAndSet(IDLE, QUEUED)) {
+                        return true;
+                    }
+                    break;
+                case QUEUED, RUNNING_QUEUED:
+                    return false;
+                case RUNNING:
+                    if (this.state.compareAndSet(RUNNING, RUNNING_QUEUED)) {
+                        return false;
+                    }
+                    break;
+                default:
+                    throw new IllegalStateException("Unknown async chunk task state: " + current);
+            }
+        }
+    }
+
+    boolean markDispatchStarted() {
+        return this.state.compareAndSet(QUEUED, RUNNING);
+    }
+
+    boolean markDispatchFinished() {
+        while (true) {
+            int current = this.state.get();
+            switch (current) {
+                case RUNNING:
+                    if (this.state.compareAndSet(RUNNING, IDLE)) {
+                        return false;
+                    }
+                    break;
+                case RUNNING_QUEUED:
+                    if (this.state.compareAndSet(RUNNING_QUEUED, IDLE)) {
+                        return true;
+                    }
+                    break;
+                default:
+                    throw new IllegalStateException("Async chunk task finished from unexpected state: " + current);
+            }
+        }
+    }
+}
