From: MC20018 <winme2001@outlook.com>
Date: Thu, 11 Jun 2026 00:47:27 +0800
Subject: [PATCH] Add canSkipTick optimization and wire EntityQueryCache

- Add Entity.canSkipTick() method with stationaryTicks tracking
- Reset stationaryTicks in setDeltaMovement()
- Add EntityQueryCache field and accessor in ServerLevel
- Clear EntityQueryCache in ServerLevel.tick()

Co-Authored-By: Claude Opus 4.8 (1M context) <noreply@anthropic.com>

diff --git a/net/minecraft/server/level/ServerLevel.java b/net/minecraft/server/level/ServerLevel.java
index 03948ac899bacf61ae4ba2754b55a21a8f35489c..b0059fb28bf9c6e5678f5681f17956ddfc933810 100644
--- a/net/minecraft/server/level/ServerLevel.java
+++ b/net/minecraft/server/level/ServerLevel.java
@@ -389,6 +389,7 @@ public class ServerLevel extends Level implements WorldGenLevel, ServerEntityGet
         this.handlingTick = true;
         this.environmentAttributes().invalidateTickCache();
         this.fandExplosionDensityCache.clear();
+        this.fandExplosionBlockCache.clear();
         this.fandTntDetonationsThisTick = 0;
         TickRateManager tickRateManager = this.tickRateManager();
         boolean runs = tickRateManager.runsNormally();
