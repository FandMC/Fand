diff --git a/net/minecraft/world/level/levelgen/NoiseBasedChunkGenerator.java b/net/minecraft/world/level/levelgen/NoiseBasedChunkGenerator.java
index 94d9cf158b42acfdb121bbf66a95d88fe4d179ea..bcaeec31c5f521a4c1bb0f5658cf5994ad517fec 100644
--- a/net/minecraft/world/level/levelgen/NoiseBasedChunkGenerator.java
+++ b/net/minecraft/world/level/levelgen/NoiseBasedChunkGenerator.java
@@ -58,6 +58,8 @@ public final class NoiseBasedChunkGenerator extends ChunkGenerator {
     private static final BlockState AIR = Blocks.AIR.defaultBlockState();
     private final Holder<NoiseGeneratorSettings> settings;
     private final Supplier<Aquifer.FluidPicker> globalFluidPicker;
+    private int fand$cachedSeaLevel;
+    private volatile boolean fand$hasCachedSeaLevel;
 
     public NoiseBasedChunkGenerator(final BiomeSource biomeSource, final Holder<NoiseGeneratorSettings> settings) {
         super(biomeSource);
@@ -483,7 +485,14 @@ public final class NoiseBasedChunkGenerator extends ChunkGenerator {
 
     @Override
     public int getSeaLevel() {
-        return this.settings.value().seaLevel();
+        if (!io.fand.server.hooks.FandHooks.worldgenSeaLevelCacheEnabled()) {
+            return this.settings.value().seaLevel();
+        }
+        if (!this.fand$hasCachedSeaLevel) {
+            this.fand$cachedSeaLevel = this.settings.value().seaLevel();
+            this.fand$hasCachedSeaLevel = true;
+        }
+        return this.fand$cachedSeaLevel;
     }
 
     @Override
diff --git a/net/minecraft/world/level/levelgen/placement/NoiseBasedCountPlacement.java b/net/minecraft/world/level/levelgen/placement/NoiseBasedCountPlacement.java
index 76eb9e00d319742bb5e954da0dbd52800cb024d7..8aaa7dcc96e6b64f36ce339f37e40cee263a6f21 100644
--- a/net/minecraft/world/level/levelgen/placement/NoiseBasedCountPlacement.java
+++ b/net/minecraft/world/level/levelgen/placement/NoiseBasedCountPlacement.java
@@ -31,6 +31,7 @@ public class NoiseBasedCountPlacement extends RepeatingPlacement {
     }
 
     @Override
+    @SuppressWarnings("removal")
     protected int count(final RandomSource random, final BlockPos origin) {
         double flowerNoise = Biome.BIOME_INFO_NOISE.getValue(origin.getX() / this.noiseFactor, origin.getZ() / this.noiseFactor, false);
         return (int)Math.ceil((flowerNoise + this.noiseOffset) * this.noiseToCountRatio);
diff --git a/net/minecraft/world/level/levelgen/placement/NoiseThresholdCountPlacement.java b/net/minecraft/world/level/levelgen/placement/NoiseThresholdCountPlacement.java
