+    private static CompletableFuture<Services> createServicesAsync(final File universePath) {
+        CompletableFuture<Services> future = new CompletableFuture<>();
+        Thread thread = new Thread(() -> {
+            try {
+                future.complete(createServices(universePath));
+            } catch (Throwable throwable) {
+                future.completeExceptionally(throwable);
+            }
+        }, "Fand Services Bootstrap");
+        thread.setDaemon(true);
+        thread.setUncaughtExceptionHandler(new DefaultUncaughtExceptionHandler(LOGGER));
+        thread.start();
+        return future;
+    }
+
+    private static Services createServices(final File universePath) {
+        var fandRuntime = io.fand.server.Main.runtimeOrNull();
+        YggdrasilAuthenticationService authenticationService;
+        if (fandRuntime == null || fandRuntime.authEnvironment() == null) {
+            authenticationService = new YggdrasilAuthenticationService(Proxy.NO_PROXY);
+        } else {
+            authenticationService = new YggdrasilAuthenticationService(Proxy.NO_PROXY, fandRuntime.authEnvironment());
+        }
+        return Services.create(authenticationService, universePath);
+    }
