 public abstract class SimpleJsonResourceReloadListener<T> extends SimplePreparableReloadListener<Map<Identifier, T>> {
     private static final Logger LOGGER = LogUtils.getLogger();
+    private static final int PARALLEL_SCAN_THRESHOLD = 128;
     private final DynamicOps<JsonElement> ops;
     private final Codec<T> codec;
     private final FileToIdConverter lister;
@@ -62,19 +66,64 @@ public abstract class SimpleJsonResourceReloadListener<T> extends SimplePreparab
     public static <T> void scanDirectory(
         final ResourceManager manager, final FileToIdConverter lister, final DynamicOps<JsonElement> ops, final Codec<T> codec, final Map<Identifier, T> result
     ) {
-        for (Entry<Identifier, Resource> entry : lister.listMatchingResources(manager).entrySet()) {
+        List<Entry<Identifier, Resource>> entries = lister.listMatchingResources(manager)
+            .entrySet()
+            .stream()
+            .sorted(Comparator.comparing(entry -> entry.getKey().toString()))
+            .toList();
+        if (entries.size() < PARALLEL_SCAN_THRESHOLD) {
+            scanDirectorySequential(lister, ops, codec, result, entries);
+            return;
+        }
+
+        List<ParsedResource<T>> parsedResources = entries.parallelStream()
+            .map(entry -> parseResource(lister, ops, codec, entry))
+            .flatMap(Optional::stream)
+            .toList();
+        mergeParsedResources(result, parsedResources);
+    }
+
+    private static <T> void scanDirectorySequential(
+        final FileToIdConverter lister,
+        final DynamicOps<JsonElement> ops,
+        final Codec<T> codec,
+        final Map<Identifier, T> result,
+        final List<Entry<Identifier, Resource>> entries
+    ) {
+        for (Entry<Identifier, Resource> entry : entries) {
+            parseResource(lister, ops, codec, entry).ifPresent(parsed -> mergeParsedResource(result, parsed));
+        }
+    }
+
+    private static <T> void mergeParsedResources(final Map<Identifier, T> result, final List<ParsedResource<T>> parsedResources) {
+        parsedResources.stream()
+            .sorted(Comparator.comparing(parsed -> parsed.id().toString()))
+            .forEach(parsed -> mergeParsedResource(result, parsed));
+    }
+
+    private static <T> void mergeParsedResource(final Map<Identifier, T> result, final ParsedResource<T> parsed) {
+        if (result.putIfAbsent(parsed.id(), parsed.value()) != null) {
+            throw new IllegalStateException("Duplicate data file ignored with ID " + parsed.id());
+        }
+    }
+
+    private static <T> Optional<ParsedResource<T>> parseResource(
+        final FileToIdConverter lister, final DynamicOps<JsonElement> ops, final Codec<T> codec, final Entry<Identifier, Resource> entry
+    ) {
             Identifier location = entry.getKey();
             Identifier id = lister.fileToId(location);
 
             try (Reader reader = entry.getValue().openAsReader()) {
-                codec.parse(ops, StrictJsonParser.parse(reader)).ifSuccess(parsed -> {
-                    if (result.putIfAbsent(id, (T)parsed) != null) {
-                        throw new IllegalStateException("Duplicate data file ignored with ID " + id);
-                    }
-                }).ifError(error -> LOGGER.error("Couldn't parse data file '{}' from '{}': {}", id, location, error));
+                return codec.parse(ops, StrictJsonParser.parse(reader))
+                    .map(parsed -> Optional.of(new ParsedResource<>(id, (T)parsed)))
+                    .resultOrPartial(error -> LOGGER.error("Couldn't parse data file '{}' from '{}': {}", id, location, error))
+                    .orElse(Optional.empty());
             } catch (JsonParseException | IllegalArgumentException | IOException e) {
                 LOGGER.error("Couldn't parse data file '{}' from '{}'", id, location, e);
+                return Optional.empty();
             }
-        }
+    }
+
+    private record ParsedResource<T>(Identifier id, T value) {
     }
