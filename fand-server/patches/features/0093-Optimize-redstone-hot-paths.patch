+    private static final class PistonDeleteList {
+        private final BlockPos[] positions;
+        private final BlockState[] states;
+        private int size;
+
+        private PistonDeleteList(final int capacity) {
+            this.positions = new BlockPos[capacity];
+            this.states = new BlockState[capacity];
+        }
+
+        private void add(final BlockPos pos, final BlockState state) {
+            this.positions[this.size] = pos;
+            this.states[this.size] = state;
+            this.size++;
+        }
+
+        private void remove(final BlockPos pos) {
+            int index = this.indexOf(pos);
+            if (index < 0) {
+                return;
+            }
+            int last = --this.size;
+            this.positions[index] = this.positions[last];
+            this.states[index] = this.states[last];
+            this.positions[last] = null;
+            this.states[last] = null;
+        }
+
+        private void replace(final BlockPos pos, final BlockState state) {
+            int index = this.indexOf(pos);
+            if (index >= 0) {
+                this.states[index] = state;
+            }
+        }
+
+        private int size() {
+            return this.size;
+        }
+
+        private BlockPos pos(final int index) {
+            return this.positions[index];
+        }
+
+        private BlockState state(final int index) {
+            return this.states[index];
+        }
+
+        private int indexOf(final BlockPos pos) {
+            for (int i = 0; i < this.size; i++) {
+                if (this.positions[i].equals(pos)) {
+                    return i;
+                }
+            }
+            return -1;
+        }
+    }
