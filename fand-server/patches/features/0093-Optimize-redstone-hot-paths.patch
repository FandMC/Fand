+    private boolean tryRunDirectShapeUpdate(
+        final BlockPos pos,
+        final Direction direction,
+        final BlockState neighborState,
+        final BlockPos neighborPos,
+        final int updateFlags,
+        final int updateLimit
+    ) {
+        if (!this.beginDirectUpdate(pos)) {
+            return false;
+        }
