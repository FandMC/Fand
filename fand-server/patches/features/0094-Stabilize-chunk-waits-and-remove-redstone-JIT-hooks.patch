@@ -163,6 +186,34 @@ public class PrepareSpawnTask implements ConfigurationTask {
         private void keepSpawnAreaWarm(final ChunkPos spawnChunk) {
             this.spawnLevel.getChunkSource().addTicketWithRadius(TicketType.PLAYER_SPAWN, spawnChunk, PREPARE_CHUNK_RADIUS);
         }
+
+        private void rescheduleCenterChunkLoad(final ChunkPos spawnChunk, final boolean warn) {
+            if (warn) {
+                this.chunkLoadTicks = 0;
+                this.chunkLoadReschedules++;
+            }
+            if (warn && (this.chunkLoadReschedules == 1 || this.chunkLoadReschedules % 6 == 0)) {
+                PrepareSpawnTask.LOGGER.warn(
+                    "Player {} is still waiting for spawn chunk {} in {}; rescheduling center chunk load (attempt {}, state: {})",
+                    PrepareSpawnTask.this.nameAndId.name(),
+                    spawnChunk,
+                    this.spawnLevel.dimension(),
+                    this.chunkLoadReschedules,
+                    this.spawnLevel.getChunkSource().describeChunkLoadState(spawnChunk)
+                );
+            }
+            this.chunkLoadFuture = this.spawnLevel.getChunkSource().addTicketAndLoadWithRadius(TicketType.PLAYER_SPAWN, spawnChunk, 0);
+            this.pollSpawnChunkTasks();
+        }
+
+        private void pollSpawnChunkTasks() {
+            ServerChunkCache chunkSource = this.spawnLevel.getChunkSource();
+            for (int i = 0; i < CHUNK_LOAD_POLL_BUDGET; i++) {
+                if (!chunkSource.pumpChunkTasks()) {
+                    break;
+                }
+            }
+        }
     }
 
     private final class Ready implements PrepareSpawnTask.State {
