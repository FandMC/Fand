+    public boolean pumpChunkTasks() {
+        boolean didWork = false;
+        if (this.runDistanceManagerUpdates()) {
+            didWork = true;
+        }
+        if (this.pollTask()) {
+            didWork = true;
+        }
+        return didWork;
+    }
