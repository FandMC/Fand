+    public @Nullable LevelChunk getChunkNowOrFutureResult(final int x, final int z) {
+        LevelChunk chunk = this.getChunkNow(x, z);
+        if (chunk != null) {
+            return chunk;
+        }
+
+        ChunkHolder chunkHolder = this.getVisibleChunkIfPresent(ChunkPos.pack(x, z));
+        if (chunkHolder == null) {
+            return null;
+        }
+
+        return chunkHolder.getFullChunkFuture().getNow(ChunkHolder.UNLOADED_LEVEL_CHUNK).orElse(null);
+    }
+
+    public String describeChunkLoadState(final ChunkPos pos) {
+        ChunkHolder chunkHolder = this.getVisibleChunkIfPresent(pos.pack());
+        if (chunkHolder == null) {
+            return "holder=missing, pendingMainThreadTasks=" + this.getPendingTasksCount();
+        }
+
+        return "ticketLevel="
+            + chunkHolder.getTicketLevel()
+            + ", queueLevel="
+            + chunkHolder.getQueueLevel()
+            + ", fullStatus="
+            + chunkHolder.getFullStatus()
+            + ", latestStatus="
+            + chunkHolder.getLatestStatus()
+            + ", fullFutureDone="
+            + chunkHolder.getFullChunkFuture().isDone()
+            + ", fullFutureSuccess="
+            + chunkHolder.getFullChunkFuture().getNow(ChunkHolder.UNLOADED_LEVEL_CHUNK).isSuccess()
+            + ", pendingMainThreadTasks="
+            + this.getPendingTasksCount();
+    }
+
