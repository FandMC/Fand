From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: MC20018 <winme2001@outlook.com>
Date: Sat, 6 Jun 2026 11:17:37 +0800
Subject: [PATCH] Fire Fand inventory open/click/close events


diff --git a/net/minecraft/server/level/ServerPlayer.java b/net/minecraft/server/level/ServerPlayer.java
index 8a4d6f02386c1222e0b636ac2d6c0a62fb8ea13e..c8543b29e18529e68f678eba8c39702dc8e8c71d 100644
--- a/net/minecraft/server/level/ServerPlayer.java
+++ b/net/minecraft/server/level/ServerPlayer.java
@@ -1372,6 +1372,9 @@ public class ServerPlayer extends Player {
 
             return OptionalInt.empty();
         } else {
+                if (!io.fand.server.inventory.InventoryEvents.fireOpen(this, menu.getType())) {
+                    return OptionalInt.empty();
+                }
             this.connection.send(new ClientboundOpenScreenPacket(menu.containerId, menu.getType(), provider.getDisplayName()));
             this.initMenu(menu);
             this.containerMenu = menu;
@@ -1441,6 +1444,9 @@ public class ServerPlayer extends Player {
 
     @Override
     public void doCloseContainer() {
+        if (this.containerMenu != this.inventoryMenu) {
+            io.fand.server.inventory.InventoryEvents.fireClose(this, this.containerMenu);
+        }
         this.containerMenu.removed(this);
         this.inventoryMenu.transferState(this.containerMenu);
         this.containerMenu = this.inventoryMenu;
diff --git a/net/minecraft/server/network/ServerGamePacketListenerImpl.java b/net/minecraft/server/network/ServerGamePacketListenerImpl.java
index 78ab7c600f9569ee39d8d904459981d08ce7fb16..b5a5e9feaafe2b9e43563317e17a1db615485137 100644
--- a/net/minecraft/server/network/ServerGamePacketListenerImpl.java
+++ b/net/minecraft/server/network/ServerGamePacketListenerImpl.java
@@ -2072,6 +2072,13 @@ public class ServerGamePacketListenerImpl
                     );
                 } else {
                     boolean fullResyncNeeded = packet.stateId() != this.player.containerMenu.getStateId();
+                    boolean fandAccepted = io.fand.server.inventory.InventoryEvents.fireClick(
+                        this.player, this.player.containerMenu, slotIndex, packet.buttonNum(), packet.containerInput()
+                    );
+                    if (!fandAccepted) {
+                        this.player.containerMenu.broadcastFullState();
+                        return;
+                    }
                     this.player.containerMenu.suppressRemoteUpdates();
                     this.player.containerMenu.clicked(slotIndex, packet.buttonNum(), packet.containerInput(), this.player);
 
