From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: MC20018 <winme2001@outlook.com>
Date: Sat, 6 Jun 2026 23:08:53 +0800
Subject: [PATCH] Fix Fand command suggestion ranges


diff --git a/net/minecraft/server/network/ServerGamePacketListenerImpl.java b/net/minecraft/server/network/ServerGamePacketListenerImpl.java
index 978d6cc988af33890e036aa96bcefb8f8fe0dfa9..e7abb34e9aed0c968943c3f10911bc49adbc4d84 100644
--- a/net/minecraft/server/network/ServerGamePacketListenerImpl.java
+++ b/net/minecraft/server/network/ServerGamePacketListenerImpl.java
@@ -596,10 +596,12 @@ public class ServerGamePacketListenerImpl
         PacketUtils.ensureRunningOnSameThread(packet, this, this.player.level());
         var fandSuggestions = io.fand.server.command.CommandBridge.suggestions(this.player.createCommandSourceStack(), packet.getCommand());
         if (fandSuggestions.isPresent()) {
-            var suggestionList = fandSuggestions.get().stream()
-                    .map(value -> new com.mojang.brigadier.suggestion.Suggestion(new com.mojang.brigadier.context.StringRange(0, packet.getCommand().length()), value))
+            var result = fandSuggestions.get();
+            var range = new com.mojang.brigadier.context.StringRange(result.replaceStart(), result.replaceEnd());
+            var suggestionList = result.values().stream()
+                    .map(value -> new com.mojang.brigadier.suggestion.Suggestion(range, value))
                     .toList();
-            this.send(new ClientboundCommandSuggestionsPacket(packet.getId(), new Suggestions(new com.mojang.brigadier.context.StringRange(0, packet.getCommand().length()), suggestionList)));
+            this.send(new ClientboundCommandSuggestionsPacket(packet.getId(), new Suggestions(range, suggestionList)));
             return;
         }
         StringReader command = new StringReader(packet.getCommand());
