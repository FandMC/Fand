diff --git a/net/minecraft/network/protocol/login/ServerboundCustomQueryAnswerPacket.java b/net/minecraft/network/protocol/login/ServerboundCustomQueryAnswerPacket.java
index 07ff6a797ac5b968e2d2d5be71a0d5d960577c54..980364a489ca10ee1ec6d927673dfd5b782c6668 100644
--- a/net/minecraft/network/protocol/login/ServerboundCustomQueryAnswerPacket.java
+++ b/net/minecraft/network/protocol/login/ServerboundCustomQueryAnswerPacket.java
@@ -1,5 +1,7 @@
 package net.minecraft.network.protocol.login;
 
+import io.fand.server.network.VelocityForwardingQueryAnswerPayload;
+import io.fand.server.network.VelocityForwardingQueryPayload;
 import net.minecraft.network.FriendlyByteBuf;
 import net.minecraft.network.codec.StreamCodec;
 import net.minecraft.network.protocol.Packet;
@@ -19,7 +21,14 @@ public record ServerboundCustomQueryAnswerPacket(int transactionId, @Nullable Cu
         return new ServerboundCustomQueryAnswerPacket(transactionId, readPayload(transactionId, input));
     }
 
-    private static CustomQueryAnswerPayload readPayload(final int transactionId, final FriendlyByteBuf input) {
+    private static @Nullable CustomQueryAnswerPayload readPayload(final int transactionId, final FriendlyByteBuf input) {
+        return input.readNullable(buf -> readSuccessfulPayload(transactionId, buf));
+    }
+
+    private static CustomQueryAnswerPayload readSuccessfulPayload(final int transactionId, final FriendlyByteBuf input) {
+        if (transactionId == VelocityForwardingQueryPayload.TRANSACTION_ID) {
+            return VelocityForwardingQueryAnswerPayload.read(input);
+        }
         return readUnknownPayload(input);
     }
 
diff --git a/net/minecraft/server/network/ServerHandshakePacketListenerImpl.java b/net/minecraft/server/network/ServerHandshakePacketListenerImpl.java
