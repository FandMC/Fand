diff --git a/net/minecraft/server/network/ServerLoginPacketListenerImpl.java b/net/minecraft/server/network/ServerLoginPacketListenerImpl.java
index 3ef1fb27f908f28627f21aa456ca3ac530038869..0ba4efa062e897c74e46be6218d238d23bd88f89 100644
--- a/net/minecraft/server/network/ServerLoginPacketListenerImpl.java
+++ b/net/minecraft/server/network/ServerLoginPacketListenerImpl.java
@@ -5,6 +5,12 @@ import com.mojang.authlib.GameProfile;
 import com.mojang.authlib.exceptions.AuthenticationUnavailableException;
 import com.mojang.authlib.yggdrasil.ProfileResult;
 import com.mojang.logging.LogUtils;
+import io.fand.server.hooks.FandHooks;
+import io.fand.server.network.ForwardedPlayerInfo;
+import io.fand.server.network.ForwardingParseException;
+import io.fand.server.network.ProxyForwardingMode;
+import io.fand.server.network.VelocityForwardingQueryAnswerPayload;
+import io.fand.server.network.VelocityForwardingQueryPayload;
 import java.math.BigInteger;
 import java.net.InetAddress;
 import java.net.InetSocketAddress;
@@ -26,6 +32,7 @@ import net.minecraft.network.chat.Component;
 import net.minecraft.network.protocol.configuration.ConfigurationProtocols;
 import net.minecraft.network.protocol.cookie.ServerboundCookieResponsePacket;
 import net.minecraft.network.protocol.login.ClientboundHelloPacket;
+import net.minecraft.network.protocol.login.ClientboundCustomQueryPacket;
 import net.minecraft.network.protocol.login.ClientboundLoginCompressionPacket;
 import net.minecraft.network.protocol.login.ClientboundLoginDisconnectPacket;
 import net.minecraft.network.protocol.login.ClientboundLoginFinishedPacket;
@@ -60,13 +67,21 @@ public class ServerLoginPacketListenerImpl implements ServerLoginPacketListener,
     private @Nullable GameProfile authenticatedProfile;
     private final String serverId = "";
     private final boolean transferred;
+    private final String requestedHostName;
 
     public ServerLoginPacketListenerImpl(final MinecraftServer minecraftserver, final Connection connection, final boolean transferred) {
+        this(minecraftserver, connection, transferred, "");
+    }
+
+    public ServerLoginPacketListenerImpl(
+        final MinecraftServer minecraftserver, final Connection connection, final boolean transferred, final String requestedHostName
+    ) {
         this.server = minecraftserver;
         this.connection = connection;
         this.serverActivityMonitor = this.server.getServerActivityMonitor();
         this.challenge = Ints.toByteArray(RandomSource.create().nextInt());
         this.transferred = transferred;
+        this.requestedHostName = requestedHostName;
     }
 
     @Override
@@ -119,6 +134,17 @@ public class ServerLoginPacketListenerImpl implements ServerLoginPacketListener,
         Validate.validState(this.state == ServerLoginPacketListenerImpl.State.HELLO, "Unexpected hello packet");
         Validate.validState(StringUtil.isValidPlayerName(packet.name()), "Invalid characters in username");
         this.requestedUsername = packet.name();
+        ProxyForwardingMode forwardingMode = FandHooks.proxyForwardingMode();
+        if (forwardingMode == ProxyForwardingMode.BUNGEE_LEGACY) {
+            this.handleBungeeForwarding(packet.name());
+            return;
+        }
+        if (forwardingMode == ProxyForwardingMode.VELOCITY_MODERN) {
+            this.state = ServerLoginPacketListenerImpl.State.NEGOTIATING;
+            this.connection.send(new ClientboundCustomQueryPacket(VelocityForwardingQueryPayload.TRANSACTION_ID, VelocityForwardingQueryPayload.INSTANCE));
+            return;
+        }
+
         GameProfile singleplayerProfile = this.server.getSingleplayerProfile();
         if (singleplayerProfile != null && this.requestedUsername.equalsIgnoreCase(singleplayerProfile.name())) {
             this.startClientVerification(singleplayerProfile);
@@ -132,6 +158,43 @@ public class ServerLoginPacketListenerImpl implements ServerLoginPacketListener,
         }
     }
 
+    private void handleBungeeForwarding(final String playerName) {
+        try {
+            this.applyForwardedInfo(FandHooks.parseBungeeLegacyForwarding(this.requestedHostName, playerName));
+        } catch (ForwardingParseException ex) {
+            LOGGER.warn("BungeeCord forwarding rejected for {}", this.getUserName(), ex);
+            this.disconnect(Component.literal("Invalid proxy forwarding data"));
+        }
+    }
+
+    private void handleVelocityForwarding(final ServerboundCustomQueryAnswerPacket packet) {
+        if (packet.transactionId() != VelocityForwardingQueryPayload.TRANSACTION_ID
+            || !(packet.payload() instanceof VelocityForwardingQueryAnswerPayload payload)) {
+            this.disconnect(Component.literal("Velocity forwarding response is missing"));
+            return;
+        }
+
+        try {
+            this.applyForwardedInfo(FandHooks.parseVelocityModernForwarding(payload));
+        } catch (ForwardingParseException ex) {
+            LOGGER.warn("Velocity forwarding rejected for {}", this.getUserName(), ex);
+            this.disconnect(Component.literal("Invalid proxy forwarding data"));
+        }
+    }
+
+    private void applyForwardedInfo(final ForwardedPlayerInfo forwarded) {
+        GameProfile profile = forwarded.profile();
+        if (!StringUtil.isValidPlayerName(profile.name())) {
+            this.disconnect(Component.literal("Invalid forwarded player name"));
+            return;
+        }
+        this.requestedUsername = profile.name();
+        this.connection.fand$setRemoteAddress(forwarded.address());
+        LOGGER.info("UUID of player {} is {}", profile.name(), profile.id());
+        this.serverActivityMonitor.reportLoginActivity();
+        this.startClientVerification(profile);
+    }
+
     private void startClientVerification(final GameProfile profile) {
         this.authenticatedProfile = profile;
         this.state = ServerLoginPacketListenerImpl.State.VERIFYING;
@@ -234,6 +297,12 @@ public class ServerLoginPacketListenerImpl implements ServerLoginPacketListener,
 
     @Override
     public void handleCustomQueryPacket(final ServerboundCustomQueryAnswerPacket packet) {
+        if (this.state == ServerLoginPacketListenerImpl.State.NEGOTIATING
+            && FandHooks.proxyForwardingMode() == ProxyForwardingMode.VELOCITY_MODERN) {
+            this.handleVelocityForwarding(packet);
+            return;
+        }
+
         this.disconnect(ServerCommonPacketListenerImpl.DISCONNECT_UNEXPECTED_QUERY);
     }
 
