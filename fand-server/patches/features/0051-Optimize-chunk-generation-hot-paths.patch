@@ -0,0 +1,68 @@
+package net.minecraft.server.level;
+
+import it.unimi.dsi.fastutil.longs.LongOpenHashSet;
+import it.unimi.dsi.fastutil.longs.LongSet;
+import java.util.List;
+import java.util.concurrent.Executor;
+import net.minecraft.util.thread.TaskScheduler;
+import net.minecraft.world.level.ChunkPos;
+import org.jspecify.annotations.Nullable;
+
+public class ParallelChunkTaskDispatcher extends ChunkTaskDispatcher {
+    // FULL generation can run block-writing statuses one chunk from the task center,
+    // and FEATURES may write one additional neighboring chunk.
+    private static final int MAX_BLOCK_WRITE_ENVELOPE_RADIUS = 2;
+    private static final int MAX_OVERLAPPING_WRITE_ENVELOPE_DISTANCE = MAX_BLOCK_WRITE_ENVELOPE_RADIUS * 2;
+    private final LongSet chunkPositionsInExecution = new LongOpenHashSet();
+    private final int maxChunksInExecution;
+
+    public ParallelChunkTaskDispatcher(final TaskScheduler<Runnable> executor, final Executor dispatcherExecutor, final int maxChunksInExecution) {
+        super(executor, dispatcherExecutor);
+        this.maxChunksInExecution = maxChunksInExecution;
+    }
+
+    @Override
+    protected ChunkTaskPriorityQueue.@Nullable TasksForChunk popTasks() {
+        return this.chunkPositionsInExecution.size() < this.maxChunksInExecution
+            ? this.popTasksAvoiding(this::overlapsActiveWriteEnvelope)
+            : null;
+    }
+
+    private boolean overlapsActiveWriteEnvelope(final long candidateChunkPos) {
+        for (long activeChunkPos : this.chunkPositionsInExecution) {
+            if (hasOverlappingWriteEnvelope(activeChunkPos, candidateChunkPos)) {
+                return true;
+            }
+        }
+
+        return false;
+    }
+
+    static boolean hasOverlappingWriteEnvelope(final long firstChunkPos, final long secondChunkPos) {
+        int distanceX = Math.abs(ChunkPos.getX(firstChunkPos) - ChunkPos.getX(secondChunkPos));
+        int distanceZ = Math.abs(ChunkPos.getZ(firstChunkPos) - ChunkPos.getZ(secondChunkPos));
+        return distanceX <= MAX_OVERLAPPING_WRITE_ENVELOPE_DISTANCE && distanceZ <= MAX_OVERLAPPING_WRITE_ENVELOPE_DISTANCE;
+    }
+
+    @Override
+    protected void scheduleForExecution(final ChunkTaskPriorityQueue.TasksForChunk tasksForChunk) {
+        if (!this.chunkPositionsInExecution.add(tasksForChunk.chunkPos())) {
+            throw new IllegalStateException("Chunk task already running for " + ChunkPos.unpack(tasksForChunk.chunkPos()));
+        }
+        List<Runnable> tasks = tasksForChunk.tasks();
+        if (tasks.isEmpty()) {
+            this.onTaskBatchComplete(tasksForChunk);
+            this.pollTask();
+        } else {
+            this.pollAfter(this.scheduleTasksSequentially(tasks), tasksForChunk);
+        }
+        if (this.chunkPositionsInExecution.size() < this.maxChunksInExecution) {
+            this.pollTask();
+        }
+    }
+
+    @Override
+    protected void onTaskBatchComplete(final ChunkTaskPriorityQueue.TasksForChunk tasksForChunk) {
+        this.chunkPositionsInExecution.remove(tasksForChunk.chunkPos());
+    }
+}
