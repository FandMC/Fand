+        Map<BlockPos, io.fand.api.component.DataComponentMap> components = new HashMap<>();
+        for (BlockPos pos : positions) {
+            components.put(pos, io.fand.server.component.BlockComponentStorage.snapshot(level, pos));
+        }
+        return components;
+    }
+
+    private static List<BlockPos> changedPlacementPositions(final Level level, final Map<BlockPos, BlockState> beforeStates) {
+        List<BlockPos> changed = new ArrayList<>();
+        for (Map.Entry<BlockPos, BlockState> entry : beforeStates.entrySet()) {
+            if (!level.getBlockState(entry.getKey()).equals(entry.getValue())) {
+                changed.add(entry.getKey());
+            }
+        }
+        if (changed.isEmpty()) {
+            changed.addAll(beforeStates.keySet().stream().filter(pos -> !level.getBlockState(pos).isAir()).limit(1).toList());
+        }
+        return changed;
+    }
