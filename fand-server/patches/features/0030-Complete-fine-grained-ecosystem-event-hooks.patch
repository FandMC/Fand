+    private static Map<BlockPos, BlockState> snapshotPlacementStates(final Level level, final BlockPos center) {
+        Map<BlockPos, BlockState> states = new HashMap<>();
+        for (BlockPos pos : BlockPos.betweenClosed(center.offset(-1, -1, -1), center.offset(1, 2, 1))) {
+            states.put(pos.immutable(), level.getBlockState(pos));
+        }
+        return states;
+    }
+
+    private static Map<BlockPos, io.fand.api.component.DataComponentMap> snapshotPlacementComponents(
+            final net.minecraft.server.level.ServerLevel level,
+            final Iterable<BlockPos> positions
