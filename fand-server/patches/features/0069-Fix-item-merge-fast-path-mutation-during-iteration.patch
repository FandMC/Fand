Subject: [PATCH] Fix item merge fast path mutation during iteration


diff --git a/net/minecraft/world/entity/item/ItemEntity.java b/net/minecraft/world/entity/item/ItemEntity.java
index 792e8d0fc13d9dcc71907c9e7a63a8cc3763ac20..6ecfd0c0881cfd1eb18da0b9b8743728d0c47297 100644
--- a/net/minecraft/world/entity/item/ItemEntity.java
+++ b/net/minecraft/world/entity/item/ItemEntity.java
@@ -1,5 +1,7 @@
 package net.minecraft.world.entity.item;
 
+import java.util.ArrayList;
+import java.util.List;
 import java.util.Objects;
 import java.util.UUID;
 import net.minecraft.core.BlockPos;
@@ -236,23 +238,25 @@ public class ItemEntity extends Entity implements TraceableEntity {
     }
 
     private void mergeWithNeighboursFast() {
-        while (this.isMergable() && !this.isRemoved()) {
-            ItemEntity[] candidate = {null};
-            this.level().forEachEntity(
-                EntityTypeTest.forClass(ItemEntity.class),
-                this.getBoundingBox().inflate(0.5, 0.0, 0.5),
-                other -> other != this && other.isMergable(),
-                other -> {
-                    candidate[0] = other;
-                    return AbortableIterationConsumer.Continuation.ABORT;
-                }
-            );
+        List<ItemEntity> candidates = new ArrayList<>();
+        this.level().forEachEntity(
+            EntityTypeTest.forClass(ItemEntity.class),
+            this.getBoundingBox().inflate(0.5, 0.0, 0.5),
+            other -> other != this && other.isMergable(),
+            other -> {
+                candidates.add(other);
+                return AbortableIterationConsumer.Continuation.CONTINUE;
+            }
+        );
 
-            if (candidate[0] == null) {
-                return;
+        for (ItemEntity entity : candidates) {
+            if (!this.isMergable() || this.isRemoved()) {
+                break;
             }
 
-            this.tryToMerge(candidate[0]);
+            if (entity.isMergable()) {
+                this.tryToMerge(entity);
+            }
         }
     }
 
