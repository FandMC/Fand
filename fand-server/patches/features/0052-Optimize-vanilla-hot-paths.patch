+    private static Stream<Entity> stream(final Iterator<Entity> iterator) {
+        return StreamSupport.stream(Spliterators.spliteratorUnknownSize(iterator, Spliterator.ORDERED | Spliterator.NONNULL), false);
+    }
+
+    private static final class SelfAndPassengersIterator implements Iterator<Entity> {
+        private final ArrayDeque<Iterator<Entity>> stack = new ArrayDeque<>();
+        private Entity next;
+
+        SelfAndPassengersIterator(final Entity root, final boolean includeRoot) {
+            if (includeRoot) {
+                this.next = root;
+            }
+            if (!root.passengers.isEmpty()) {
+                this.stack.addLast(root.passengers.iterator());
+            }
+        }
+
+        @Override
+        public boolean hasNext() {
+            if (this.next != null) {
+                return true;
+            }
+
+            while (!this.stack.isEmpty()) {
+                Iterator<Entity> iterator = this.stack.peekLast();
+                if (iterator.hasNext()) {
+                    Entity entity = iterator.next();
+                    this.next = entity;
+                    if (!entity.passengers.isEmpty()) {
+                        this.stack.addLast(entity.passengers.iterator());
+                    }
+                    return true;
+                }
+                this.stack.removeLast();
+            }
+
+            return false;
+        }
+
+        @Override
+        public Entity next() {
+            if (!this.hasNext()) {
+                throw new java.util.NoSuchElementException();
+            }
+            Entity entity = this.next;
+            this.next = null;
+            return entity;
+        }
+    }
+
+    private static final class PassengersAndSelfIterator implements Iterator<Entity> {
+        private final ArrayDeque<PassengerFrame> stack = new ArrayDeque<>();
+        private Entity next;
+
+        PassengersAndSelfIterator(final Entity root) {
+            this.stack.addLast(new PassengerFrame(root));
+        }
+
+        @Override
+        public boolean hasNext() {
+            if (this.next != null) {
+                return true;
+            }
+
+            while (!this.stack.isEmpty()) {
+                PassengerFrame frame = this.stack.peekLast();
+                if (frame.passengers.hasNext()) {
+                    this.stack.addLast(new PassengerFrame(frame.passengers.next()));
+                    continue;
+                }
+                this.stack.removeLast();
+                this.next = frame.entity;
+                return true;
+            }
+
+            return false;
+        }
+
+        @Override
+        public Entity next() {
+            if (!this.hasNext()) {
+                throw new java.util.NoSuchElementException();
+            }
+            Entity entity = this.next;
+            this.next = null;
+            return entity;
+        }
+    }
+
+    private static final class PassengerFrame {
