+    private void runUpdateFastQueue() {
+        int totalSize = Math.min(this.lightTaskRunnables.size(), this.taskPerBatch);
+
+        for (int i = 0; i < totalSize; i++) {
+            if (this.lightTaskTypes.get(i) == ThreadedLevelLightEngine.TaskType.PRE_UPDATE) {
+                this.lightTaskRunnables.get(i).run();
+            }
+        }
+
+        super.runLightUpdates();
+
+        int processed = 0;
+        try {
+            for (; processed < totalSize; processed++) {
+                if (this.lightTaskTypes.get(processed) == ThreadedLevelLightEngine.TaskType.POST_UPDATE) {
+                    this.lightTaskRunnables.get(processed).run();
+                }
+            }
+        } finally {
+            if (processed > 0) {
+                this.lightTaskTypes.removeElements(0, processed);
+                this.lightTaskRunnables.removeElements(0, processed);
+            }
+        }
+    }
