+import net.minecraft.world.phys.shapes.BooleanOp;
+import net.minecraft.world.phys.shapes.Shapes;
+import net.minecraft.world.phys.shapes.VoxelShape;
 import net.minecraft.world.scores.Scoreboard;
 import org.apache.commons.lang3.mutable.MutableBoolean;
+import org.apache.commons.lang3.mutable.MutableObject;
 import org.jspecify.annotations.Nullable;
 
 public abstract class Level implements LevelAccessor, AutoCloseable {
@@ -867,8 +873,135 @@ public abstract class Level implements LevelAccessor, AutoCloseable {
         return hasEntities.isTrue();
     }
 
+    @Override
+    public boolean isUnobstructed(final @Nullable Entity source, final VoxelShape shape) {
+        if (shape.isEmpty()) {
+            return true;
+        }
+        Profiler.get().incrementCounter("getEntities");
+        AABB bounds = shape.bounds();
+        MutableBoolean obstructed = new MutableBoolean();
+        this.getEntities().get(EntityTypeTest.forClass(Entity.class), bounds, entity -> {
+            if (!entity.isRemoved()
+                && entity != source
+                && EntitySelector.NO_SPECTATORS.test(entity)
+                && entity.blocksBuilding
+                && (source == null || !entity.isPassengerOfSameVehicle(source))
+                && Shapes.joinIsNotEmpty(shape, Shapes.create(entity.getBoundingBox()), BooleanOp.AND)) {
+                obstructed.setTrue();
+                return AbortableIterationConsumer.Continuation.ABORT;
+            }
+            return AbortableIterationConsumer.Continuation.CONTINUE;
+        });
+        if (obstructed.isTrue()) {
+            return false;
+        }
+
+        for (EnderDragonPart dragonPart : this.dragonParts()) {
+            if (dragonPart != source
+                && dragonPart.parentMob != source
+                && !dragonPart.isRemoved()
+                && EntitySelector.NO_SPECTATORS.test(dragonPart)
+                && dragonPart.blocksBuilding
+                && (source == null || !dragonPart.isPassengerOfSameVehicle(source))
+                && Shapes.joinIsNotEmpty(shape, Shapes.create(dragonPart.getBoundingBox()), BooleanOp.AND)) {
+                return false;
+            }
+        }
+        return true;
+    }
+
+    @Override
+    public boolean noEntityCollision(final @Nullable Entity entity, final AABB aabb) {
+        if (aabb.getSize() < 1.0E-7) {
+            return true;
+        }
+
+        Profiler.get().incrementCounter("getEntities");
+        Predicate<Entity> canCollide = entity == null ? EntitySelector.CAN_BE_COLLIDED_WITH : EntitySelector.NO_SPECTATORS.and(entity::canCollideWith);
+        AABB searchArea = aabb.inflate(1.0E-7);
+        MutableBoolean collided = new MutableBoolean();
+        this.getEntities().getEntityCollisionCandidates(searchArea, candidate -> {
+            if (candidate != entity && canCollide.test(candidate)) {
+                collided.setTrue();
+                return AbortableIterationConsumer.Continuation.ABORT;
+            }
+            return AbortableIterationConsumer.Continuation.CONTINUE;
+        });
+        if (collided.isTrue()) {
+            return false;
+        }
+
+        for (EnderDragonPart dragonPart : this.dragonParts()) {
+            if (dragonPart != entity && dragonPart.parentMob != entity && canCollide.test(dragonPart) && searchArea.intersects(dragonPart.getBoundingBox())) {
+                return false;
+            }
+        }
+        return true;
+    }
+
+    @Override
+    public List<VoxelShape> getEntityCollisions(final @Nullable Entity source, final AABB testArea) {
+        if (testArea.getSize() < 1.0E-7) {
+            return List.of();
+        }
+
+        Profiler.get().incrementCounter("getEntities");
+        Predicate<Entity> canCollide = source == null ? EntitySelector.CAN_BE_COLLIDED_WITH : EntitySelector.NO_SPECTATORS.and(source::canCollideWith);
+        MutableObject<Builder<VoxelShape>> shapes = new MutableObject<>();
+        MutableBoolean found = new MutableBoolean();
+        AABB searchArea = testArea.inflate(1.0E-7);
+        this.getEntities().getEntityCollisionCandidates(searchArea, entity -> {
+            if (entity != source && canCollide.test(entity)) {
+                found.setTrue();
+                if (shapes.getValue() == null) {
+                    shapes.setValue(ImmutableList.builder());
+                }
+                shapes.getValue().add(Shapes.create(entity.getBoundingBox()));
+            }
+            return AbortableIterationConsumer.Continuation.CONTINUE;
+        });
+
+        for (EnderDragonPart dragonPart : this.dragonParts()) {
+            if (dragonPart != source && dragonPart.parentMob != source && canCollide.test(dragonPart) && searchArea.intersects(dragonPart.getBoundingBox())) {
+                found.setTrue();
+                if (shapes.getValue() == null) {
+                    shapes.setValue(ImmutableList.builder());
+                }
+                shapes.getValue().add(Shapes.create(dragonPart.getBoundingBox()));
+            }
+        }
+
+        return found.isTrue() ? shapes.getValue().build() : List.of();
+    }
+
     public List<Entity> getPushableEntities(final Entity pusher, final AABB boundingBox) {
-        return this.getEntities(pusher, boundingBox, EntitySelector.pushableBy(pusher));
+        Profiler.get().incrementCounter("getEntities");
+        Predicate<Entity> selector = EntitySelector.pushableBy(pusher);
+        MutableObject<List<Entity>> output = new MutableObject<>();
+        this.getEntities().getEntityCollisionCandidates(boundingBox, entity -> {
+            if (entity != pusher && selector.test(entity)) {
+                if (output.getValue() == null) {
+                    output.setValue(Lists.newArrayList());
+                }
+                output.getValue().add(entity);
+            }
+            return AbortableIterationConsumer.Continuation.CONTINUE;
+        });
+
+        for (EnderDragonPart dragonPart : this.dragonParts()) {
+            if (dragonPart != pusher
+                && dragonPart.parentMob != pusher
+                && selector.test(dragonPart)
+                && boundingBox.intersects(dragonPart.getBoundingBox())) {
+                if (output.getValue() == null) {
+                    output.setValue(Lists.newArrayList());
+                }
+                output.getValue().add(dragonPart);
+            }
+        }
+
+        return output.getValue() == null ? List.of() : output.getValue();
     }
 
     public abstract @Nullable Entity getEntity(int id);
diff --git a/net/minecraft/world/level/entity/EntitySection.java b/net/minecraft/world/level/entity/EntitySection.java
index 9c2711e4c209682ac280b08c2f1bf0e1f44d5c94..1328a710b5ee20c1d1ccfa0500ef4aa6bcf6f298 100644
--- a/net/minecraft/world/level/entity/EntitySection.java
+++ b/net/minecraft/world/level/entity/EntitySection.java
@@ -6,24 +6,37 @@ import java.util.stream.Stream;
 import net.minecraft.util.AbortableIterationConsumer;
 import net.minecraft.util.ClassInstanceMultiMap;
 import net.minecraft.util.VisibleForDebug;
+import net.minecraft.world.entity.Entity;
 import net.minecraft.world.phys.AABB;
 import org.slf4j.Logger;
 
 public class EntitySection<T extends EntityAccess> {
     private static final Logger LOGGER = LogUtils.getLogger();
+    private static final ClassValue<Boolean> ENTITY_COLLISION_CANDIDATE_TYPES = new ClassValue<>() {
+        @Override
+        protected Boolean computeValue(final Class<?> type) {
+            return declaresEntityCollisionMethod(type, "canBeCollidedWith", Entity.class) || declaresEntityCollisionMethod(type, "isPushable");
+        }
+    };
     private final ClassInstanceMultiMap<T> storage;
+    private final ClassInstanceMultiMap<T> entityCollisionCandidates;
     private Visibility chunkStatus;
 
     public EntitySection(final Class<T> entityClass, final Visibility chunkStatus) {
         this.chunkStatus = chunkStatus;
         this.storage = new ClassInstanceMultiMap<>(entityClass);
+        this.entityCollisionCandidates = new ClassInstanceMultiMap<>(entityClass);
     }
 
     public void add(final T entity) {
         this.storage.add(entity);
+        if (couldCollideWithMovingEntity(entity)) {
+            this.entityCollisionCandidates.add(entity);
+        }
     }
 
     public boolean remove(final T entity) {
+        this.entityCollisionCandidates.remove(entity);
         return this.storage.remove(entity);
     }
 
@@ -37,6 +50,16 @@ public class EntitySection<T extends EntityAccess> {
         return AbortableIterationConsumer.Continuation.CONTINUE;
     }
 
+    public AbortableIterationConsumer.Continuation getEntityCollisionCandidates(final AABB bb, final AbortableIterationConsumer<T> entities) {
+        for (T entity : this.entityCollisionCandidates) {
+            if (entity.getBoundingBox().intersects(bb) && entities.accept(entity).shouldAbort()) {
+                return AbortableIterationConsumer.Continuation.ABORT;
+            }
+        }
+
+        return AbortableIterationConsumer.Continuation.CONTINUE;
+    }
+
     public <U extends T> AbortableIterationConsumer.Continuation getEntities(
         final EntityTypeTest<T, U> type, final AABB bb, final AbortableIterationConsumer<? super U> consumer
     ) {
@@ -77,4 +100,18 @@ public class EntitySection<T extends EntityAccess> {
     public int size() {
         return this.storage.size();
     }
+
+    private static boolean couldCollideWithMovingEntity(final EntityAccess entity) {
+        return entity instanceof Entity minecraftEntity
+            && ENTITY_COLLISION_CANDIDATE_TYPES.get(minecraftEntity.getClass());
+    }
+
+    private static boolean declaresEntityCollisionMethod(final Class<?> type, final String name, final Class<?>... parameterTypes) {
+        try {
+            return type.getMethod(name, parameterTypes).getDeclaringClass() != Entity.class;
+        } catch (NoSuchMethodException ex) {
+            LOGGER.warn("Unable to inspect entity collision method {} on {}", name, type.getName(), ex);
+            return true;
+        }
+    }
 }
