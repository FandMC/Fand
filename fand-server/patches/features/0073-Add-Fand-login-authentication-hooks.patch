@@ -139,8 +138,11 @@ public class ServerLoginPacketListenerImpl implements ServerLoginPacketListener,
     @Override
     public void handleHello(final ServerboundHelloPacket packet) {
         Validate.validState(this.state == ServerLoginPacketListenerImpl.State.HELLO, "Unexpected hello packet");
-        Validate.validState(StringUtil.isValidPlayerName(packet.name()), "Invalid characters in username");
+        Validate.validState(
+                !FandHooks.validateLoginUsernames() || StringUtil.isValidPlayerName(packet.name()),
+                "Invalid characters in username");
         this.requestedUsername = packet.name();
+        this.requestedProfileId = packet.profileId();
         ProxyForwardingMode forwardingMode = FandHooks.proxyForwardingMode();
         if (forwardingMode == ProxyForwardingMode.BUNGEE_LEGACY) {
             this.handleBungeeForwarding(packet.name());
@@ -157,6 +159,28 @@ public class ServerLoginPacketListenerImpl implements ServerLoginPacketListener,
             this.startClientVerification(singleplayerProfile);
         } else {
             if (this.server.usesAuthentication() && !this.connection.isMemoryConnection()) {
+                var pluginAttempt = FandHooks.authenticateLoginPlugins(new io.fand.api.auth.LoginAuthenticationRequest(
+                        this.requestedUsername,
+                        this.serverId,
+                        this.connection.getRemoteAddress(),
+                        null,
+                        this.requestedProfileId
+                ));
+                switch (pluginAttempt.status()) {
+                    case PASS -> {
+                    }
+                    case DENY -> {
+                        this.disconnect(Objects.requireNonNull(pluginAttempt.reason(), "Login denial reason missing"));
+                        return;
+                    }
+                    case ALLOW -> {
+                        GameProfile profile = Objects.requireNonNull(pluginAttempt.profile(), "Login allow result missing profile");
+                        LOGGER.info("UUID of player {} is {}", profile.name(), profile.id());
+                        this.serverActivityMonitor.reportLoginActivity();
+                        this.startClientVerification(profile);
+                        return;
+                    }
+                }
                 this.state = ServerLoginPacketListenerImpl.State.KEY;
                 this.connection.send(new ClientboundHelloPacket("", this.server.getKeyPair().getPublic().getEncoded(), this.challenge, true));
             } else {
@@ -277,31 +301,22 @@ public class ServerLoginPacketListenerImpl implements ServerLoginPacketListener,
             @Override
             public void run() {
                 String name = Objects.requireNonNull(ServerLoginPacketListenerImpl.this.requestedUsername, "Player name not initialized");
-
-                try {
-                    ProfileResult result = ServerLoginPacketListenerImpl.this.server
-                        .services()
-                        .sessionService()
-                        .hasJoinedServer(name, digest, this.getAddress());
-                    if (result != null) {
-                        GameProfile profile = result.profile();
+                var request = new io.fand.api.auth.LoginAuthenticationRequest(
+                        name,
+                        digest,
+                        ServerLoginPacketListenerImpl.this.connection.getRemoteAddress(),
+                        this.getAddress(),
+                        ServerLoginPacketListenerImpl.this.requestedProfileId
+                );
+                var attempt = FandHooks.authenticateLogin(request);
+                switch (attempt.status()) {
+                    case PASS -> ServerLoginPacketListenerImpl.this.disconnect(Component.translatable("multiplayer.disconnect.unverified_username"));
+                    case DENY -> ServerLoginPacketListenerImpl.this.disconnect(Objects.requireNonNull(attempt.reason(), "Login denial reason missing"));
+                    case ALLOW -> {
+                        GameProfile profile = Objects.requireNonNull(attempt.profile(), "Login allow result missing profile");
                         ServerLoginPacketListenerImpl.LOGGER.info("UUID of player {} is {}", profile.name(), profile.id());
                         ServerLoginPacketListenerImpl.this.serverActivityMonitor.reportLoginActivity();
                         ServerLoginPacketListenerImpl.this.startClientVerification(profile);
-                    } else if (ServerLoginPacketListenerImpl.this.server.isSingleplayer()) {
-                        ServerLoginPacketListenerImpl.LOGGER.warn("Failed to verify username but will let them in anyway!");
-                        ServerLoginPacketListenerImpl.this.startClientVerification(UUIDUtil.createOfflineProfile(name));
-                    } else {
-                        ServerLoginPacketListenerImpl.this.disconnect(Component.translatable("multiplayer.disconnect.unverified_username"));
-                        ServerLoginPacketListenerImpl.LOGGER.error("Username '{}' tried to join with an invalid session", name);
-                    }
-                } catch (AuthenticationUnavailableException ignored) {
-                    if (ServerLoginPacketListenerImpl.this.server.isSingleplayer()) {
-                        ServerLoginPacketListenerImpl.LOGGER.warn("Authentication servers are down but will let them in anyway!");
-                        ServerLoginPacketListenerImpl.this.startClientVerification(UUIDUtil.createOfflineProfile(name));
-                    } else {
-                        ServerLoginPacketListenerImpl.this.disconnect(Component.translatable("multiplayer.disconnect.authservers_down"));
-                        ServerLoginPacketListenerImpl.LOGGER.error("Couldn't verify username because servers are unavailable");
                     }
                 }
             }
