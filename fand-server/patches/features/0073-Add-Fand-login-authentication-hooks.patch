Subject: [PATCH] Add Fand login authentication hooks


diff --git a/net/minecraft/server/Main.java b/net/minecraft/server/Main.java
index eb1e6c8a0bf7abd6fc066704f2358354b33ad0e6..1f6a666a51d94f06403e7a4afae3f642a936a2f8 100644
--- a/net/minecraft/server/Main.java
+++ b/net/minecraft/server/Main.java
@@ -123,7 +123,14 @@ public class Main {
             }
 
             File universePath = new File(options.valueOf(universe));
-            Services services = Services.create(new YggdrasilAuthenticationService(Proxy.NO_PROXY), universePath);
+            var fandRuntime = io.fand.server.Main.runtimeOrNull();
+            YggdrasilAuthenticationService authenticationService;
+            if (fandRuntime == null || fandRuntime.authEnvironment() == null) {
+                authenticationService = new YggdrasilAuthenticationService(Proxy.NO_PROXY);
+            } else {
+                authenticationService = new YggdrasilAuthenticationService(Proxy.NO_PROXY, fandRuntime.authEnvironment());
+            }
+            Services services = Services.create(authenticationService, universePath);
             NotificationManager notificationManager = new NotificationManager();
             ManagementServer jsonRpcServer = JsonRpc.create(settings, notificationManager);
             String levelName = Optional.ofNullable(options.valueOf(worldName)).orElse(settings.getProperties().levelName);
