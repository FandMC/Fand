@@ -64,6 +62,7 @@ public class ServerLoginPacketListenerImpl implements ServerLoginPacketListener,
     private volatile ServerLoginPacketListenerImpl.State state = ServerLoginPacketListenerImpl.State.HELLO;
     private int tick;
