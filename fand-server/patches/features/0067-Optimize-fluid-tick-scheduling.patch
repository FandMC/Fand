+    private void rebuildContainerQueueIfNeeded() {
+        int liveSchedules = this.nextTickForContainer.size();
+        long rebuildAt = (long) liveSchedules * QUEUED_SCHEDULE_REBUILD_FACTOR + QUEUED_SCHEDULE_REBUILD_EXTRA;
+        if (this.containersByNextTick.size() <= rebuildAt && this.staleQueuedSchedules <= liveSchedules + QUEUED_SCHEDULE_REBUILD_EXTRA) {
+            return;
+        }
+        this.rebuildContainerQueue();
+    }
