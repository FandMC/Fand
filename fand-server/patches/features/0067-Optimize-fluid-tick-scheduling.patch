+    private void syncContainerQueueMode() {
+        boolean enabled = this.containerQueueEnabled.getAsBoolean();
+        if (enabled == this.containerQueueActive) {
+            return;
+        }
+        this.containerQueueActive = enabled;
+        this.containersByNextTick.clear();
+        this.queuedTickForContainer.clear();
+        this.staleQueuedSchedules = 0;
+        if (enabled) {
+            ObjectIterator<Entry> it = Long2LongMaps.fastIterator(this.nextTickForContainer);
+            while (it.hasNext()) {
+                Entry entry = it.next();
+                this.queueContainerSchedule(entry.getLongKey(), entry.getLongValue());
+            }
+        }
+    }
