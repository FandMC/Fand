+    private void sortContainersToTickQueued(final long currentTick) {
+        this.rebuildContainerQueueIfNeeded();
+        ContainerSchedule entry;
+        while ((entry = this.containersByNextTick.peek()) != null && entry.queueTick <= currentTick) {
+            this.containersByNextTick.poll();
+            if (this.queuedTickForContainer.get(entry.chunkPos) == entry.triggerTick) {
+                this.queuedTickForContainer.remove(entry.chunkPos);
+            }
+            long scheduledTick = this.nextTickForContainer.get(entry.chunkPos);
+            if (scheduledTick != entry.triggerTick) {
+                this.staleQueuedSchedules++;
+                continue;
+            }
+            LevelChunkTicks<T> candidateContainer = this.allContainers.get(entry.chunkPos);
+            if (candidateContainer == null) {
+                this.nextTickForContainer.remove(entry.chunkPos);
+                continue;
+            }
+            ScheduledTick<T> scheduledTickEntry = candidateContainer.peek();
+            if (scheduledTickEntry == null) {
+                this.nextTickForContainer.remove(entry.chunkPos);
+                this.queuedTickForContainer.remove(entry.chunkPos);
+            } else if (scheduledTickEntry.triggerTick() > currentTick) {
+                this.updateContainerScheduling(scheduledTickEntry);
+            } else if (this.tickCheck.test(entry.chunkPos)) {
+                this.nextTickForContainer.remove(entry.chunkPos);
+                this.queuedTickForContainer.remove(entry.chunkPos);
+                this.containersToTick.add(candidateContainer);
+            } else {
+                this.queueContainerSchedule(entry.chunkPos, scheduledTickEntry.triggerTick(), currentTick + 1L);
+            }
+        }
+        this.rebuildContainerQueueIfNeeded();
+    }
