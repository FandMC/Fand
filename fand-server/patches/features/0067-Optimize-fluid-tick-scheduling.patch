+    private void spreadToSidesArray(final ServerLevel level, final BlockPos pos, final BlockState state) {
+        FlowingFluid.SpreadTargets targets = SPREAD_TARGETS.get();
+        int count = this.getSpreadArray(level, pos, state, targets.directions, targets.fluids);
+        try {
+            for (int i = 0; i < count; i++) {
+                Direction spread = targets.directions[i];
+                BlockPos neighborPos = pos.relative(spread);
+                this.spreadTo(level, neighborPos, level.getBlockState(neighborPos), spread, targets.fluids[i]);
+            }
+        } finally {
+            targets.clear(count);
+        }
+    }
