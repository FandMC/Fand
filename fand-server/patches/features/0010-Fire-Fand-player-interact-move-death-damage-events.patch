diff --git a/net/minecraft/world/entity/LivingEntity.java b/net/minecraft/world/entity/LivingEntity.java
index fcdd1af00d0cfd662d4070d9254887ef4edb7f5b..ee5db7960eb489119104edd907c9f02ab1f7dbaa 100644
--- a/net/minecraft/world/entity/LivingEntity.java
+++ b/net/minecraft/world/entity/LivingEntity.java
@@ -1187,6 +1187,35 @@ public abstract class LivingEntity extends Entity implements Attackable, Waypoin
             return false;
         }
 
+        if (io.fand.server.Main.runtime().events().hasListeners(io.fand.api.event.entity.EntityDamageEvent.class)) {
+            io.fand.api.entity.LivingEntity fandVictim = null;
+            if (this instanceof net.minecraft.server.level.ServerPlayer fandServerPlayer) {
+                fandVictim = io.fand.server.Main.runtime().playerRegistry().find(fandServerPlayer.getUUID()).orElse(null);
+            } else {
+                var fandWorldRegistry = io.fand.server.Main.runtime().worldRegistry().orElse(null);
+                if (fandWorldRegistry != null) {
+                    fandVictim = new io.fand.server.entity.FandLivingEntity(this, fandWorldRegistry);
+                }
+            }
+            if (fandVictim != null) {
+                var fandDamageType = source.typeHolder().unwrapKey().map(k -> k.identifier().toString()).orElse("minecraft:generic");
+                var fandDamageEvent = new io.fand.api.event.entity.EntityDamageEvent(fandVictim, fandDamageType, damage);
+                try {
+                    io.fand.server.Main.runtime().events().fire(fandDamageEvent);
+                } catch (RuntimeException fandFailure) {
+                    org.slf4j.LoggerFactory.getLogger(LivingEntity.class).warn("EntityDamageEvent listener failed", fandFailure);
+                }
+                if (fandDamageEvent.cancelled()) {
+                    return false;
+                }
+                double fandAdjusted = fandDamageEvent.amount();
+                if (fandAdjusted < 0.0) {
+                    fandAdjusted = 0.0;
+                }
+                damage = (float) fandAdjusted;
+            }
+        }
+
         if (this.isSleeping()) {
             this.stopSleeping();
         }
