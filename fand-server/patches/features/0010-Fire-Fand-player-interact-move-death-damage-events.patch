diff --git a/net/minecraft/world/entity/LivingEntity.java b/net/minecraft/world/entity/LivingEntity.java
index 0c10a086b7edb97718825553db1da3f14a6f87f6..d02fada406531ad4d69cfb44afe3d0a2ab386d4f 100644
--- a/net/minecraft/world/entity/LivingEntity.java
+++ b/net/minecraft/world/entity/LivingEntity.java
@@ -1157,6 +1157,27 @@ public abstract class LivingEntity extends Entity implements Attackable, Waypoin
         } else if (source.is(DamageTypeTags.IS_FIRE) && this.hasEffect(MobEffects.FIRE_RESISTANCE)) {
             return false;
         } else {
+            if (this instanceof net.minecraft.server.level.ServerPlayer fandServerPlayer
+                    && io.fand.server.Main.runtime().events().hasListeners(io.fand.api.event.player.PlayerDamageEvent.class)) {
+                var fandPlayer = io.fand.server.Main.runtime().playerRegistry().find(fandServerPlayer.getUUID()).orElse(null);
+                if (fandPlayer != null) {
+                    var fandDamageType = source.typeHolder().unwrapKey().map(k -> k.identifier().toString()).orElse("minecraft:generic");
+                    var fandDamageEvent = new io.fand.api.event.player.PlayerDamageEvent(fandPlayer, fandDamageType, damage);
+                    try {
+                        io.fand.server.Main.runtime().events().fire(fandDamageEvent);
+                    } catch (RuntimeException fandFailure) {
+                        org.slf4j.LoggerFactory.getLogger(LivingEntity.class).warn("PlayerDamageEvent listener failed", fandFailure);
+                    }
+                    if (fandDamageEvent.cancelled()) {
+                        return false;
+                    }
+                    double fandAdjusted = fandDamageEvent.amount();
+                    if (fandAdjusted < 0.0) {
+                        fandAdjusted = 0.0;
+                    }
+                    damage = (float) fandAdjusted;
+                }
+            }
             if (this.isSleeping()) {
                 this.stopSleeping();
             }
