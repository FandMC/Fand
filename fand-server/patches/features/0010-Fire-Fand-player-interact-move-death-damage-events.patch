From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: MC20018 <winme2001@outlook.com>
Date: Fri, 5 Jun 2026 20:11:02 +0800
Subject: [PATCH] Fire Fand player interact/move/death/damage events


diff --git a/net/minecraft/server/level/ServerPlayer.java b/net/minecraft/server/level/ServerPlayer.java
index 7c70afcfee9450f62372b0c3a27bef13804cc15c..8a4d6f02386c1222e0b636ac2d6c0a62fb8ea13e 100644
--- a/net/minecraft/server/level/ServerPlayer.java
+++ b/net/minecraft/server/level/ServerPlayer.java
@@ -885,15 +885,41 @@ public class ServerPlayer extends Player {
     public void die(final DamageSource source) {
         this.gameEvent(GameEvent.ENTITY_DIE);
         boolean showDeathMessage = this.level().getGameRules().get(GameRules.SHOW_DEATH_MESSAGES);
-        if (showDeathMessage) {
-            Component deathMessage = this.getCombatTracker().getDeathMessage();
+        Component deathMessage = showDeathMessage ? this.getCombatTracker().getDeathMessage() : null;
+        if (io.fand.server.Main.runtime().events().hasListeners(io.fand.api.event.player.PlayerDeathEvent.class)) {
+            var fandPlayer = io.fand.server.Main.runtime().playerRegistry().find(this.getUUID()).orElse(null);
+            if (fandPlayer != null) {
+                net.kyori.adventure.text.Component fandDeathMessage = null;
+                if (deathMessage != null) {
+                    try {
+                        fandDeathMessage = io.fand.server.command.AdventureBridge.fromVanilla(deathMessage, this.registryAccess());
+                    } catch (RuntimeException fandFailure) {
+                        LOGGER.warn("Skipping PlayerDeathEvent after fromVanilla failure", fandFailure);
+                    }
+                }
+                var fandDeathEvent = new io.fand.api.event.player.PlayerDeathEvent(fandPlayer, fandDeathMessage);
+                try {
+                    io.fand.server.Main.runtime().events().fire(fandDeathEvent);
+                } catch (RuntimeException fandFailure) {
+                    LOGGER.warn("PlayerDeathEvent listener failed", fandFailure);
+                }
+                if (fandDeathEvent.deathMessage() == null) {
+                    showDeathMessage = false;
+                    deathMessage = null;
+                } else if (deathMessage != null) {
+                    deathMessage = io.fand.server.command.AdventureBridge.toVanillaOrFallback(fandDeathEvent.deathMessage(), deathMessage, this.registryAccess());
+                }
+            }
+        }
+        if (showDeathMessage && deathMessage != null) {
+            final Component finalDeathMessage = deathMessage;
             this.connection
                 .send(
-                    new ClientboundPlayerCombatKillPacket(this.getId(), deathMessage),
+                    new ClientboundPlayerCombatKillPacket(this.getId(), finalDeathMessage),
                     PacketSendListener.exceptionallySend(
                         () -> {
                             int truncatedMessageSize = 256;
-                            String truncatedDeathMessage = deathMessage.getString(256);
+                            String truncatedDeathMessage = finalDeathMessage.getString(256);
                             Component explanation = Component.translatable(
                                 "death.attack.message_too_long", Component.literal(truncatedDeathMessage).withStyle(ChatFormatting.YELLOW)
                             );
@@ -905,11 +931,11 @@ public class ServerPlayer extends Player {
                 );
             Team team = this.getTeam();
             if (team == null || team.getDeathMessageVisibility() == Team.Visibility.ALWAYS) {
-                this.server.getPlayerList().broadcastSystemMessage(deathMessage, false);
+                this.server.getPlayerList().broadcastSystemMessage(finalDeathMessage, false);
             } else if (team.getDeathMessageVisibility() == Team.Visibility.HIDE_FOR_OTHER_TEAMS) {
-                this.server.getPlayerList().broadcastSystemToTeam(this, deathMessage);
+                this.server.getPlayerList().broadcastSystemToTeam(this, finalDeathMessage);
             } else if (team.getDeathMessageVisibility() == Team.Visibility.HIDE_FOR_OWN_TEAM) {
-                this.server.getPlayerList().broadcastSystemToAllExceptTeam(this, deathMessage);
+                this.server.getPlayerList().broadcastSystemToAllExceptTeam(this, finalDeathMessage);
             }
         } else {
             this.connection.send(new ClientboundPlayerCombatKillPacket(this.getId(), CommonComponents.EMPTY));
