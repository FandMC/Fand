From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: MC20018 <winme2001@outlook.com>
Date: Sun, 7 Jun 2026 12:49:46 +0800
Subject: [PATCH] Expose richer Fand event context


diff --git a/net/minecraft/server/network/ServerGamePacketListenerImpl.java b/net/minecraft/server/network/ServerGamePacketListenerImpl.java
index c668e107239286b1b70285d7306d74e0d15026e1..21daa4b7833df93ceb1ec9a31dc0b5ac812fdfbe 100644
--- a/net/minecraft/server/network/ServerGamePacketListenerImpl.java
+++ b/net/minecraft/server/network/ServerGamePacketListenerImpl.java
@@ -1419,7 +1419,8 @@ public class ServerGamePacketListenerImpl
                                                         fandPlayer,
                                                         io.fand.api.event.player.PlayerInteractEvent.Action.RIGHT_CLICK_BLOCK,
                                                         fandHand,
-                                                        fandBlock),
+                                                        fandBlock,
+                                                        io.fand.server.item.FandItemStacks.fromVanilla(itemStack)),
                                                 "PlayerInteractEvent");
                                         if (fandInteractEvent.cancelled()) {
                                             this.send(new ClientboundBlockUpdatePacket(level, pos));
@@ -1502,7 +1503,8 @@ public class ServerGamePacketListenerImpl
                                         fandPlayer,
                                         io.fand.api.event.player.PlayerInteractEvent.Action.RIGHT_CLICK_AIR,
                                         fandHand,
-                                        java.util.Optional.empty()),
+                                        java.util.Optional.empty(),
+                                        io.fand.server.item.FandItemStacks.fromVanilla(itemStack)),
                                 "PlayerInteractEvent");
                         if (fandInteractEvent.cancelled()) {
                             return;
diff --git a/net/minecraft/world/entity/LivingEntity.java b/net/minecraft/world/entity/LivingEntity.java
index 8b187f802ff1c69e4dcc8b12f47ab9344e6206c7..e9dd47e1d82f5f3f06522d868185dc956239c3e8 100644
--- a/net/minecraft/world/entity/LivingEntity.java
+++ b/net/minecraft/world/entity/LivingEntity.java
@@ -1192,9 +1192,20 @@ public abstract class LivingEntity extends Entity implements Attackable, Waypoin
             io.fand.api.entity.LivingEntity fandVictim = io.fand.server.hooks.FandHooks.wrapLivingEntity(this);
             if (fandVictim != null) {
                 var fandDamageType = source.typeHolder().unwrapKey().map(k -> k.identifier().toString()).orElse("minecraft:generic");
+                    var fandDirectEntity = java.util.Optional.ofNullable(source.getDirectEntity())
+                            .filter(entity -> entity instanceof net.minecraft.world.entity.LivingEntity)
+                            .map(entity -> io.fand.server.hooks.FandHooks.wrapLivingEntity((net.minecraft.world.entity.LivingEntity) entity));
+                    var fandAttacker = java.util.Optional.ofNullable(source.getEntity())
+                            .filter(entity -> entity instanceof net.minecraft.world.entity.LivingEntity)
+                            .map(entity -> io.fand.server.hooks.FandHooks.wrapLivingEntity((net.minecraft.world.entity.LivingEntity) entity));
                 var fandDamageEvent = io.fand.server.hooks.FandHooks.fireOrLog(
                         fandBus,
-                        new io.fand.api.event.entity.EntityDamageEvent(fandVictim, fandDamageType, damage),
+                            new io.fand.api.event.entity.EntityDamageEvent(
+                                    fandVictim,
+                                    fandDamageType,
+                                    damage,
+                                    fandDirectEntity,
+                                    fandAttacker),
                         "EntityDamageEvent");
                 if (fandDamageEvent.cancelled()) {
                     return false;
