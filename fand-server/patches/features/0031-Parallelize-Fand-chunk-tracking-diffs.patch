+    private boolean submitFandChunkTrackingDiff(final ServerPlayer player, final ChunkTrackingView previous, final ChunkTrackingView next) {
+        if (!(next instanceof ChunkTrackingView.Positioned)) {
+            this.fandChunkTrackingDiffs.remove(player.getUUID());
+            return false;
+        }
+        io.fand.server.chunk.ChunkTrackingSnapshot pending = this.fandChunkTrackingDiffs.get(player.getUUID());
+        if (pending != null && pending.sameTarget(fandCenter(next), fandViewDistance(next))) {
+            return true;
+        }
+        long sequence = FAND_CHUNK_TRACKING_SEQUENCE.incrementAndGet();
+        var snapshot = new io.fand.server.chunk.ChunkTrackingSnapshot(
+            player.getUUID(),
+            sequence,
+            fandCenter(previous),
+            fandViewDistance(previous),
+            previous instanceof ChunkTrackingView.Positioned,
+            fandCenter(next),
+            fandViewDistance(next),
+            next instanceof ChunkTrackingView.Positioned,
+            fandChunks(previous),
+            fandChunks(next)
+        );
+        this.fandChunkTrackingDiffs.put(player.getUUID(), snapshot);
+        if (io.fand.server.hooks.FandHooks.submitChunkTrackingDiff(this.level, snapshot)) {
+            return true;
+        }
+        this.fandChunkTrackingDiffs.remove(player.getUUID(), snapshot);
+        return false;
+    }
+
+    private boolean applyFandChunkTrackingDiff(final io.fand.server.chunk.ChunkTrackingDiff diff) {
+        ServerPlayer player = this.level.getServer().getPlayerList().getPlayer(diff.snapshot().playerId());
+        if (player == null || player.level() != this.level) {
+            this.fandChunkTrackingDiffs.remove(diff.snapshot().playerId(), diff.snapshot());
+            return false;
+        }
+        io.fand.server.chunk.ChunkTrackingSnapshot pending = this.fandChunkTrackingDiffs.get(diff.snapshot().playerId());
+        if (pending != diff.snapshot()) {
+            return false;
+        }
+        ChunkTrackingView current = player.getChunkTrackingView();
+        if (!fandSameView(current, diff.snapshot().previousPositioned(), diff.snapshot().previousCenter(), diff.snapshot().previousViewDistance())) {
+            this.fandChunkTrackingDiffs.remove(diff.snapshot().playerId(), diff.snapshot());
+            return false;
+        }
+
+        ChunkPos nextCenter = ChunkPos.unpack(diff.snapshot().nextCenter());
+        ChunkTrackingView next = ChunkTrackingView.of(nextCenter, diff.snapshot().nextViewDistance());
+        if (!(current instanceof ChunkTrackingView.Positioned from && from.center().equals(nextCenter))) {
+            player.connection.send(new ClientboundSetChunkCacheCenterPacket(nextCenter.x(), nextCenter.z()));
+        }
+        diff.leave().forEach(pos -> dropChunk(player, ChunkPos.unpack(pos)));
+        diff.enter().forEach(pos -> this.markChunkPendingToSend(player, ChunkPos.unpack(pos)));
+        player.setChunkTrackingView(next);
+        this.fandChunkTrackingDiffs.remove(diff.snapshot().playerId(), diff.snapshot());
+        return true;
+    }
+
+    private static boolean fandSameView(
+        final ChunkTrackingView view,
+        final boolean positioned,
+        final long center,
+        final int viewDistance
+    ) {
+        if (!positioned) {
+            return !(view instanceof ChunkTrackingView.Positioned);
+        }
+        return view instanceof ChunkTrackingView.Positioned current
+            && current.center().pack() == center
+            && current.viewDistance() == viewDistance;
+    }
+
+    private static long fandCenter(final ChunkTrackingView view) {
+        return view instanceof ChunkTrackingView.Positioned positioned ? positioned.center().pack() : 0L;
+    }
+
+    private static int fandViewDistance(final ChunkTrackingView view) {
+        return view instanceof ChunkTrackingView.Positioned positioned ? positioned.viewDistance() : 0;
+    }
+
+    private static it.unimi.dsi.fastutil.longs.LongList fandChunks(final ChunkTrackingView view) {
+        var chunks = new it.unimi.dsi.fastutil.longs.LongArrayList();
+        view.forEach(pos -> chunks.add(pos.pack()));
+        return chunks;
+    }
+
