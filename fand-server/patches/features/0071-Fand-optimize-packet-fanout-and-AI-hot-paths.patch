-            this.protocolInfo.codec().encode(output, packet);
-            int writtenBytes = output.readableBytes();
+            int startIndex = output.writerIndex();
+            this.encodePacket(packet, output);
+            int writtenBytes = output.writerIndex() - startIndex;
             if (LOGGER.isDebugEnabled()) {
                 LOGGER.debug(
                     Connection.PACKET_SENT_MARKER,
@@ -47,4 +49,24 @@ public class PacketEncoder<T extends PacketListener> extends MessageToByteEncode
             ProtocolSwapHandler.handleOutboundTerminalPacket(ctx, packet);
         }
     }
+
+    private void encodePacket(final Packet<T> packet, final ByteBuf output) {
+        if (!io.fand.server.hooks.FandHooks.reusablePacketEncodingEnabled() || !(packet instanceof ReusablePacketEncoding reusable)) {
+            this.protocolInfo.codec().encode(output, packet);
+            return;
+        }
+
+        byte[] cached = reusable.fand$cachedEncoding(this.protocolInfo.id());
+        if (cached != null) {
+            output.writeBytes(cached);
+            return;
+        }
+
+        int startIndex = output.writerIndex();
+        this.protocolInfo.codec().encode(output, packet);
+        int encodedLength = output.writerIndex() - startIndex;
+        byte[] encoded = new byte[encodedLength];
+        output.getBytes(startIndex, encoded);
+        reusable.fand$cacheEncoding(this.protocolInfo.id(), encoded);
+    }
 }
