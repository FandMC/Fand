diff --git a/net/minecraft/world/level/levelgen/structure/structures/FandTemplateStructure.java b/net/minecraft/world/level/levelgen/structure/structures/FandTemplateStructure.java
new file mode 100644
index 0000000000000000000000000000000000000000..25cc314a46aa0c48cafc391337eea569e2b34c5f
--- /dev/null
+++ b/net/minecraft/world/level/levelgen/structure/structures/FandTemplateStructure.java
@@ -0,0 +1,157 @@
+package net.minecraft.world.level.levelgen.structure.structures;
+
+import com.mojang.serialization.Codec;
+import com.mojang.serialization.MapCodec;
+import com.mojang.serialization.codecs.RecordCodecBuilder;
+import java.util.Optional;
+import net.minecraft.core.BlockPos;
+import net.minecraft.nbt.CompoundTag;
+import net.minecraft.resources.Identifier;
+import net.minecraft.util.RandomSource;
+import net.minecraft.world.level.ChunkPos;
+import net.minecraft.world.level.ServerLevelAccessor;
+import net.minecraft.world.level.StructureManager;
+import net.minecraft.world.level.WorldGenLevel;
+import net.minecraft.world.level.block.Mirror;
+import net.minecraft.world.level.block.Rotation;
+import net.minecraft.world.level.chunk.ChunkGenerator;
+import net.minecraft.world.level.levelgen.Heightmap;
+import net.minecraft.world.level.levelgen.structure.BoundingBox;
+import net.minecraft.world.level.levelgen.structure.Structure;
+import net.minecraft.world.level.levelgen.structure.StructureType;
+import net.minecraft.world.level.levelgen.structure.TemplateStructurePiece;
+import net.minecraft.world.level.levelgen.structure.pieces.StructurePieceSerializationContext;
+import net.minecraft.world.level.levelgen.structure.pieces.StructurePieceType;
+import net.minecraft.world.level.levelgen.structure.templatesystem.BlockIgnoreProcessor;
+import net.minecraft.world.level.levelgen.structure.templatesystem.LiquidSettings;
+import net.minecraft.world.level.levelgen.structure.templatesystem.StructurePlaceSettings;
+import net.minecraft.world.level.levelgen.structure.templatesystem.StructureTemplateManager;
+
+public final class FandTemplateStructure extends Structure {
+    public static final MapCodec<FandTemplateStructure> CODEC = RecordCodecBuilder.mapCodec(
+        i -> i.group(
+                settingsCodec(i),
+                Identifier.CODEC.fieldOf("template").forGetter(structure -> structure.template),
+                Codec.BOOL.optionalFieldOf("include_entities", true).forGetter(structure -> structure.includeEntities),
+                Heightmap.Types.CODEC.optionalFieldOf("heightmap", Heightmap.Types.WORLD_SURFACE_WG).forGetter(structure -> structure.heightmap),
+                Codec.INT.optionalFieldOf("y_offset", 0).forGetter(structure -> structure.yOffset)
+            )
+            .apply(i, FandTemplateStructure::new)
+    );
+
+    private final Identifier template;
+    private final boolean includeEntities;
+    private final Heightmap.Types heightmap;
+    private final int yOffset;
+
+    public FandTemplateStructure(
+        final Structure.StructureSettings settings,
+        final Identifier template,
+        final boolean includeEntities,
+        final Heightmap.Types heightmap,
+        final int yOffset
+    ) {
+        super(settings);
+        this.template = template;
+        this.includeEntities = includeEntities;
+        this.heightmap = heightmap;
+        this.yOffset = yOffset;
+    }
+
+    @Override
+    protected Optional<Structure.GenerationStub> findGenerationPoint(final Structure.GenerationContext context) {
+        ChunkPos chunkPos = context.chunkPos();
+        int x = chunkPos.getMiddleBlockX();
+        int z = chunkPos.getMiddleBlockZ();
+        int y = context.chunkGenerator().getFirstOccupiedHeight(x, z, this.heightmap, context.heightAccessor(), context.randomState()) + this.yOffset;
+        BlockPos position = new BlockPos(x, y, z);
+        return Optional.of(new Structure.GenerationStub(position, builder -> builder.addPiece(new FandTemplateStructure.Piece(
+            context.structureTemplateManager(),
+            this.template,
+            position,
+            Rotation.NONE,
+            this.includeEntities
+        ))));
+    }
+
+    @Override
+    public StructureType<?> type() {
+        return StructureType.FAND_TEMPLATE;
+    }
+
+    public static final class Piece extends TemplateStructurePiece {
+        private final boolean includeEntities;
+
+        public Piece(
+            final StructureTemplateManager structureTemplateManager,
+            final Identifier template,
+            final BlockPos position,
+            final Rotation rotation,
+            final boolean includeEntities
+        ) {
+            super(
+                StructurePieceType.FAND_TEMPLATE,
+                0,
+                structureTemplateManager,
+                template,
+                template.toString(),
+                makeSettings(rotation, includeEntities),
+                position
+            );
+            this.includeEntities = includeEntities;
+        }
+
+        public Piece(final StructureTemplateManager structureTemplateManager, final CompoundTag tag) {
+            super(
+                StructurePieceType.FAND_TEMPLATE,
+                tag,
+                structureTemplateManager,
+                location -> makeSettings(tag.read("Rot", Rotation.LEGACY_CODEC).orElse(Rotation.NONE), tag.getBooleanOr("IncludeEntities", true))
+            );
+            this.includeEntities = tag.getBooleanOr("IncludeEntities", true);
+        }
+
+        private static StructurePlaceSettings makeSettings(final Rotation rotation, final boolean includeEntities) {
+            return new StructurePlaceSettings()
+                .setRotation(rotation)
+                .setMirror(Mirror.NONE)
+                .setIgnoreEntities(!includeEntities)
+                .setKnownShape(true)
+                .setFinalizeEntities(includeEntities)
+                .setLiquidSettings(LiquidSettings.APPLY_WATERLOGGING)
+                .addProcessor(BlockIgnoreProcessor.STRUCTURE_BLOCK);
+        }
+
+        @Override
+        protected void addAdditionalSaveData(final StructurePieceSerializationContext context, final CompoundTag tag) {
+            super.addAdditionalSaveData(context, tag);
+            tag.store("Rot", Rotation.LEGACY_CODEC, this.placeSettings.getRotation());
+            tag.putBoolean("IncludeEntities", this.includeEntities);
+        }
+
+        @Override
+        protected void handleDataMarker(
+            final String markerId,
+            final BlockPos position,
+            final ServerLevelAccessor level,
+            final RandomSource random,
+            final BoundingBox chunkBB
+        ) {
+        }
+
+        @Override
+        public void postProcess(
+            final WorldGenLevel level,
+            final StructureManager structureManager,
+            final ChunkGenerator generator,
+            final RandomSource random,
+            final BoundingBox chunkBB,
+            final ChunkPos chunkPos,
+            final BlockPos referencePos
+        ) {
+            this.placeSettings.setIgnoreEntities(!this.includeEntities);
+            this.placeSettings.setFinalizeEntities(this.includeEntities);
+            super.postProcess(level, structureManager, generator, random, chunkBB, chunkPos, referencePos);
+        }
+    }
+}
