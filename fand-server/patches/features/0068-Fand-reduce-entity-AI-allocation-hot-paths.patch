+    private void applyEffectsFast(final ServerLevel serverLevel, final List<MobEffectInstance> allEffects, final float radius) {
+        List<LivingEntity> affectedEntities = new ArrayList<>(4);
+        double radiusSqr = radius * radius;
+        this.level().forEachEntity(
+            EntityTypeTest.forClass(LivingEntity.class),
+            this.getBoundingBox(),
+            entity -> this.canApplyTo(entity, allEffects) && this.isInsideRadius(entity, radiusSqr),
+            entity -> {
+                affectedEntities.add(entity);
+                return AbortableIterationConsumer.Continuation.CONTINUE;
+            }
+        );
+
+        if (affectedEntities.isEmpty()) {
+            return;
+        }
+
+        List<LivingEntity> eventEntities = io.fand.server.event.EntityEvents.fireAreaEffectCloudApply(this, affectedEntities);
+        if (eventEntities == null) {
+            eventEntities = List.of();
+        }
+
+        float mutableRadius = radius;
+        for (LivingEntity entity : eventEntities) {
+            if (this.canApplyTo(entity, allEffects)) {
+                this.victims.put(entity, this.tickCount + this.reapplicationDelay);
+                for (MobEffectInstance effect : allEffects) {
+                    if (effect.getEffect().value().isInstantaneous()) {
+                        effect.getEffect().value().applyInstantaneousEffect(serverLevel, this, this.getOwner(), entity, effect.getAmplifier(), 0.5);
+                    } else {
+                        entity.addEffect(new MobEffectInstance(effect), this);
+                    }
+                }
+
+                if (this.radiusOnUse != 0.0F) {
+                    mutableRadius += this.radiusOnUse;
+                    if (mutableRadius < 0.5F) {
+                        this.discard();
+                        return;
+                    }
+
+                    this.setRadius(mutableRadius);
+                }
+
+                if (this.durationOnUse != 0 && this.duration != -1) {
+                    this.duration = this.duration + this.durationOnUse;
+                    if (this.duration <= 0) {
+                        this.discard();
+                        return;
+                    }
+                }
+            }
+        }
+    }
+
+    private boolean canApplyTo(final LivingEntity entity, final List<MobEffectInstance> effects) {
+        if (this.victims.containsKey(entity) || !entity.isAffectedByPotions()) {
+            return false;
+        }
+
+        for (MobEffectInstance effect : effects) {
+            if (entity.canBeAffected(effect)) {
+                return true;
+            }
+        }
+
+        return false;
+    }
+
+    private boolean isInsideRadius(final LivingEntity entity, final double radiusSqr) {
+        double xd = entity.getX() - this.getX();
+        double zd = entity.getZ() - this.getZ();
+        return xd * xd + zd * zd <= radiusSqr;
+    }
+
     public float getRadiusOnUse() {
         return this.radiusOnUse;
     }
