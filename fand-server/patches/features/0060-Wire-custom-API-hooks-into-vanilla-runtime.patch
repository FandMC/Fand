+    private io.fand.server.event.EntityEvents.DamageBreakdown fand$calculateDamageBreakdown(
+            final ServerLevel level,
+            final DamageSource source,
+            float damage
+    ) {
+        float baseDamage = damage;
+        java.util.EnumMap<io.fand.api.event.entity.DamageModifier, Double> modifiers =
+            new java.util.EnumMap<>(io.fand.api.event.entity.DamageModifier.class);
+        modifiers.put(io.fand.api.event.entity.DamageModifier.BASE, (double) baseDamage);
+
+        float damageBlocked = this.fand$resolveBlockedDamage(source, damage);
+        if (damageBlocked > 0.0F) {
+            modifiers.put(io.fand.api.event.entity.DamageModifier.BLOCKING, (double) -damageBlocked);
+        }
+        damage -= damageBlocked;
+        if (source.is(DamageTypeTags.IS_FREEZING) && this.is(EntityTypeTags.FREEZE_HURTS_EXTRA_TYPES)) {
+            float previousDamage = damage;
+            damage *= 5.0F;
+            modifiers.put(io.fand.api.event.entity.DamageModifier.FREEZING, (double) (damage - previousDamage));
+        }
+
+        float damageBeforeHelmet = damage;
+        if (source.is(DamageTypeTags.DAMAGES_HELMET) && !this.getItemBySlot(EquipmentSlot.HEAD).isEmpty()) {
+            float previousDamage = damage;
+            damage *= 0.75F;
+            modifiers.put(io.fand.api.event.entity.DamageModifier.HARD_HAT, (double) (damage - previousDamage));
+        }
+
+        if (Float.isNaN(damage) || Float.isInfinite(damage)) {
+            damage = Float.MAX_VALUE;
+        }
+
+        float damageBeforeArmor = damage;
+        if (!source.is(DamageTypeTags.BYPASSES_ARMOR)) {
+            float afterArmor = CombatRules.getDamageAfterAbsorb(
+                this, damage, source, this.getArmorValue(), (float)this.getAttributeValue(Attributes.ARMOR_TOUGHNESS)
+            );
+            modifiers.put(io.fand.api.event.entity.DamageModifier.ARMOR, (double) (afterArmor - damage));
+            damage = afterArmor;
+        }
+
+        float damageBeforeResistance = damage;
+        float resistedDamage = 0.0F;
+        if (!source.is(DamageTypeTags.BYPASSES_EFFECTS)
+                && this.hasEffect(MobEffects.RESISTANCE)
+                && !source.is(DamageTypeTags.BYPASSES_RESISTANCE)) {
+            int absorbValue = (this.getEffect(MobEffects.RESISTANCE).getAmplifier() + 1) * 5;
+            int absorb = 25 - absorbValue;
+            float resisted = Math.max(damage * absorb / 25.0F, 0.0F);
+            resistedDamage = damage - resisted;
+            modifiers.put(io.fand.api.event.entity.DamageModifier.RESISTANCE, (double) -resistedDamage);
+            damage = resisted;
+        }
+
+        if (damage > 0.0F && !source.is(DamageTypeTags.BYPASSES_ENCHANTMENTS)) {
+            float enchantmentArmor = EnchantmentHelper.getDamageProtection(level, this, source);
+            if (enchantmentArmor > 0.0F) {
+                float afterEnchantments = CombatRules.getDamageAfterMagicAbsorb(damage, enchantmentArmor);
+                modifiers.put(io.fand.api.event.entity.DamageModifier.ENCHANTMENTS, (double) (afterEnchantments - damage));
+                damage = afterEnchantments;
+            }
+        }
+
+        float customDamage = this.fand$applyCustomDamageReduction(source, damage);
+        if (customDamage != damage) {
+            modifiers.put(io.fand.api.event.entity.DamageModifier.CUSTOM, (double) (customDamage - damage));
+            damage = customDamage;
+        }
+
+        float originalDamage = damage;
+        damage = Math.max(damage - this.getAbsorptionAmount(), 0.0F);
+        float absorbedDamage = originalDamage - damage;
+        if (absorbedDamage > 0.0F) {
+            modifiers.put(io.fand.api.event.entity.DamageModifier.ABSORPTION, (double) -absorbedDamage);
+        }
+
+        return new io.fand.server.event.EntityEvents.DamageBreakdown(
+            baseDamage,
+            damageBlocked,
+            damageBeforeHelmet,
+            damageBeforeArmor,
+            damageBeforeResistance,
+            resistedDamage,
+            absorbedDamage,
+            damage,
+            modifiers);
+    }
