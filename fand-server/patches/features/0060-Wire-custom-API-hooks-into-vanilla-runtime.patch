diff --git a/net/minecraft/core/MappedRegistry.java b/net/minecraft/core/MappedRegistry.java
index 4a881a234d827a78da9569cbb9dde7eab0cddd7d..d469a2dcce62351dfe6a119bcea67f09b2d01e39 100644
--- a/net/minecraft/core/MappedRegistry.java
+++ b/net/minecraft/core/MappedRegistry.java
@@ -120,6 +120,55 @@ public class MappedRegistry<T> implements WritableRegistry<T> {
         return holder;
     }
 
+    public Holder.Reference<T> fand$registerRuntime(final ResourceKey<T> key, final T value, final RegistrationInfo registrationInfo) {
+        if (!this.frozen) {
+            Holder.Reference<T> existing = this.byKey.get(key);
+            if (existing != null) {
+                return this.fand$replaceRuntime(key, value, registrationInfo, existing);
+            }
+            return this.register(key, value, registrationInfo);
+        }
+
+        this.frozen = false;
+        try {
+            Holder.Reference<T> existing = this.byKey.get(key);
+            if (existing != null) {
+                return this.fand$replaceRuntime(key, value, registrationInfo, existing);
+            }
+            Holder.Reference<T> holder = this.register(key, value, registrationInfo);
+            holder.bindValue(value);
+            holder.bindTags(List.of());
+            holder.bindComponents(net.minecraft.core.component.DataComponentMap.EMPTY);
+            this.componentLookup = new DataComponentLookup<>(this.byId);
+            return holder;
+        } finally {
+            this.frozen = true;
+        }
+    }
+
+    private Holder.Reference<T> fand$replaceRuntime(
+        final ResourceKey<T> key,
+        final T value,
+        final RegistrationInfo registrationInfo,
+        final Holder.Reference<T> holder
+    ) {
+        T previous = holder.value();
+        int id = this.toId.removeInt(previous);
+        if (id < 0) {
+            id = this.byId.indexOf(holder);
+        }
+
+        this.byValue.remove(previous);
+        this.byValue.put(value, holder);
+        this.toId.put(value, id);
+        this.registrationInfos.put(key, registrationInfo);
+        this.registryLifecycle = this.registryLifecycle.add(registrationInfo.lifecycle());
+        holder.bindValue(value);
+        holder.bindComponents(net.minecraft.core.component.DataComponentMap.EMPTY);
+        this.componentLookup = new DataComponentLookup<>(this.byId);
+        return holder;
+    }
+
     @Override
     public @Nullable Identifier getKey(final T thing) {
         Holder.Reference<T> holder = this.byValue.get(thing);
