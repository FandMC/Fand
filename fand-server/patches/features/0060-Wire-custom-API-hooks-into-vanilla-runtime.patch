+    private float fand$resolveBlockedDamage(final DamageSource source, final float damage) {
+        if (damage <= 0.0F) {
+            return 0.0F;
+        }
+
+        ItemStack blockingWith = this.getItemBlockingWith();
+        if (blockingWith == null) {
+            return 0.0F;
+        }
+
+        BlocksAttacks blocksAttacks = blockingWith.get(DataComponents.BLOCKS_ATTACKS);
+        if (blocksAttacks == null || blocksAttacks.bypassedBy().map(t -> t.contains(source.typeHolder())).orElse(false)) {
+            return 0.0F;
+        }
+
+        if (source.getDirectEntity() instanceof AbstractArrow abstractArrow && abstractArrow.getPierceLevel() > 0) {
+            return 0.0F;
+        }
+
+        Vec3 sourcePosition = source.getSourcePosition();
+        double angle;
+        if (sourcePosition != null) {
+            Vec3 viewVector = this.calculateViewVector(0.0F, this.getYHeadRot());
+            Vec3 vectorTo = sourcePosition.subtract(this.position());
+            vectorTo = new Vec3(vectorTo.x, 0.0, vectorTo.z).normalize();
+            angle = Math.acos(vectorTo.dot(viewVector));
+        } else {
+            angle = (float) Math.PI;
+        }
+
+        return blocksAttacks.resolveBlockedDamage(source, damage, angle);
+    }
+
+    private float fand$applyItemBlocking(
+            final ServerLevel level,
+            final DamageSource source,
+            final float damage,
+            final float damageBlocked
+    ) {
+        if (damageBlocked <= 0.0F) {
+            return 0.0F;
+        }
+
+        ItemStack blockingWith = this.getItemBlockingWith();
+        BlocksAttacks blocksAttacks = blockingWith == null ? null : blockingWith.get(DataComponents.BLOCKS_ATTACKS);
+        if (blocksAttacks == null) {
+            return 0.0F;
+        }
+
+        blocksAttacks.hurtBlockingItem(this.level(), blockingWith, this, this.getUsedItemHand(), damageBlocked);
+        if (!source.is(DamageTypeTags.IS_PROJECTILE) && source.getDirectEntity() instanceof LivingEntity livingEntity) {
+            this.blockUsingItem(level, livingEntity, source, damage);
+        }
+
+        return damageBlocked;
+    }
+
+    protected float fand$applyCustomDamageReduction(final DamageSource source, final float damage) {
+        return damage;
+    }
+
+    protected void fand$applyFinalDamage(
+            final ServerLevel level,
+            final DamageSource source,
+            float damage,
+            final io.fand.server.event.EntityEvents.DamageBreakdown breakdown
+    ) {
+        if (this.isInvulnerableTo(level, source)) {
+            return;
+        }
+
+        if (!source.is(DamageTypeTags.BYPASSES_ARMOR)) {
+            this.hurtArmor(source, breakdown.damageBeforeArmor());
+        }
+        this.fand$awardResistanceStats(source, breakdown.resistedDamage());
+        float absorbedDamage = Math.min(this.getAbsorptionAmount(), Math.max(breakdown.absorbedDamage(), 0.0F));
+        if (absorbedDamage > 0.0F) {
+            this.setAbsorptionAmount(this.getAbsorptionAmount() - absorbedDamage);
+            if (absorbedDamage < 3.4028235E37F && source.getEntity() instanceof ServerPlayer serverPlayer) {
+                serverPlayer.awardStat(Stats.DAMAGE_DEALT_ABSORBED, Math.round(absorbedDamage * 10.0F));
+            }
+        }
+
+        if (damage != 0.0F) {
+            this.getCombatTracker().recordDamage(source, damage);
+            this.setHealth(this.getHealth() - damage);
+            this.setAbsorptionAmount(this.getAbsorptionAmount() - damage);
+            this.gameEvent(GameEvent.ENTITY_DAMAGE);
+        }
+    }
+
+    private void fand$awardResistanceStats(final DamageSource source, final float resistedDamage) {
+        if (resistedDamage <= 0.0F || resistedDamage >= 3.4028235E37F) {
+            return;
+        }
+
+        if (this instanceof ServerPlayer serverPlayer) {
+            serverPlayer.awardStat(Stats.DAMAGE_RESISTED, Math.round(resistedDamage * 10.0F));
+        } else if (source.getEntity() instanceof ServerPlayer) {
+            ((ServerPlayer)source.getEntity()).awardStat(Stats.DAMAGE_DEALT_RESISTED, Math.round(resistedDamage * 10.0F));
+        }
+    }
