+    private List<ItemStack> fandDefaultDeathDrops() {
+        var drops = new ArrayList<ItemStack>();
+        Inventory inventory = this.getInventory();
+        for (int slot = 0; slot < inventory.getContainerSize(); slot++) {
+            ItemStack itemStack = inventory.getItem(slot);
+            if (!itemStack.isEmpty() && !EnchantmentHelper.has(itemStack, EnchantmentEffectComponents.PREVENT_EQUIPMENT_DROP)) {
+                drops.add(itemStack.copy());
+            }
+        }
+        return drops;
+    }
+
+    private void fandApplyDeathDrops(io.fand.server.event.PlayerEvents.DeathResult deathResult) {
+        if (!deathResult.keepInventory()) {
+            this.getInventory().clearContent();
+        }
+        for (ItemStack itemStack : deathResult.drops()) {
+            this.drop(itemStack.copy(), true, false);
+        }
+        if (!deathResult.keepExperience() && deathResult.droppedExperience() > 0) {
+            ExperienceOrb.award(this.level(), this.position(), deathResult.droppedExperience());
+        }
+    }
