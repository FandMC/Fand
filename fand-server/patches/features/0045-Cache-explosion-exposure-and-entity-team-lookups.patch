From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: MC20018 <winme2001@outlook.com>
Date: Wed, 10 Jun 2026 19:47:27 +0800
Subject: [PATCH] Cache explosion exposure and entity team lookups

Explosions resolve entity exposure through a per-level cache keyed by
center block and entity bounding box, cleared each level tick, so TNT
chains stop re-tracing identical ray sets per entity per explosion.

Entity.getTeam() caches its scoreboard lookup against a membership
version bumped on team mutations, removing the string-keyed map lookup
from every collision pair in dense entity stacks.

Both paths are gated by fand.yml performance switches.

diff --git a/net/minecraft/server/level/ServerLevel.java b/net/minecraft/server/level/ServerLevel.java
index 93d1b0f0e686ed1bf40171929cb3003d6ddd97f0..ec387987121c563cc0487015fdb3d071658f32f9 100644
--- a/net/minecraft/server/level/ServerLevel.java
+++ b/net/minecraft/server/level/ServerLevel.java
@@ -221,6 +221,11 @@ public class ServerLevel extends Level implements WorldGenLevel, ServerEntityGet
     private final StructureCheck structureCheck;
     private final boolean tickTime;
     private final LevelDebugSynchronizers debugSynchronizers = new LevelDebugSynchronizers(this);
+    private final io.fand.server.world.ExplosionDensityCache fandExplosionDensityCache = new io.fand.server.world.ExplosionDensityCache();
+
+    public io.fand.server.world.ExplosionDensityCache fand$explosionDensityCache() {
+        return this.fandExplosionDensityCache;
+    }
 
     public ServerLevel(
         final MinecraftServer server,
@@ -354,6 +359,7 @@ public class ServerLevel extends Level implements WorldGenLevel, ServerEntityGet
         ProfilerFiller profiler = Profiler.get();
         this.handlingTick = true;
         this.environmentAttributes().invalidateTickCache();
+        this.fandExplosionDensityCache.clear();
         TickRateManager tickRateManager = this.tickRateManager();
         boolean runs = tickRateManager.runsNormally();
         if (runs) {
diff --git a/net/minecraft/world/entity/Entity.java b/net/minecraft/world/entity/Entity.java
index 5d5e9821834b6f5881b1c69ce40b9792e4aeefa9..9bf959e8a932b52bb1b3c9f49d6fce452fcc52a5 100644
--- a/net/minecraft/world/entity/Entity.java
+++ b/net/minecraft/world/entity/Entity.java
@@ -2193,6 +2193,7 @@ public abstract class Entity
             input.read("UUID", UUIDUtil.CODEC).ifPresent(id -> {
                 this.uuid = id;
                 this.stringUUID = this.uuid.toString();
+                this.fandCachedTeamScoreboard = null;
             });
             if (!Double.isFinite(this.getX()) || !Double.isFinite(this.getY()) || !Double.isFinite(this.getZ())) {
                 throw new IllegalStateException("Entity has invalid position");
@@ -2860,9 +2861,23 @@ public abstract class Entity
     }
 
     public @Nullable PlayerTeam getTeam() {
-        return this.level().getScoreboard().getPlayersTeam(this.getScoreboardName());
+        Scoreboard scoreboard = this.level().getScoreboard();
+        if (!io.fand.server.hooks.FandHooks.collisionTeamCacheEnabled()) {
+            return scoreboard.getPlayersTeam(this.getScoreboardName());
+        }
+        int version = scoreboard.fand$teamMembershipVersion();
+        if (this.fandCachedTeamScoreboard != scoreboard || this.fandCachedTeamVersion != version) {
+            this.fandCachedTeam = scoreboard.getPlayersTeam(this.getScoreboardName());
+            this.fandCachedTeamScoreboard = scoreboard;
+            this.fandCachedTeamVersion = version;
+        }
+        return this.fandCachedTeam;
     }
 
+    private @Nullable PlayerTeam fandCachedTeam;
+    private @Nullable Scoreboard fandCachedTeamScoreboard;
+    private int fandCachedTeamVersion;
+
     public final boolean isAlliedTo(final @Nullable Entity other) {
         return other != null && (this == other || this.considersEntityAsAlly(other) || other.considersEntityAsAlly(this));
     }
@@ -3355,6 +3370,7 @@ public abstract class Entity
     public void setUUID(final UUID uuid) {
         this.uuid = uuid;
         this.stringUUID = this.uuid.toString();
+        this.fandCachedTeamScoreboard = null;
     }
 
     @Override
diff --git a/net/minecraft/world/level/ServerExplosion.java b/net/minecraft/world/level/ServerExplosion.java
index 0185818adcf689dfb03be6bdeb7d73aa532b2054..addcff811697785b81df0738773caa5ff79fa6de 100644
--- a/net/minecraft/world/level/ServerExplosion.java
+++ b/net/minecraft/world/level/ServerExplosion.java
@@ -109,6 +109,13 @@ public class ServerExplosion implements Explosion {
         }
     }
 
+    private float fandSeenPercent(final Entity entity) {
+        if (io.fand.server.hooks.FandHooks.explosionDensityCacheEnabled()) {
+            return this.level.fand$explosionDensityCache().seenPercent(this.center, entity);
+        }
+        return getSeenPercent(this.center, entity);
+    }
+
     @Override
     public float radius() {
         return this.radius;
@@ -191,7 +198,7 @@ public class ServerExplosion implements Explosion {
                         Vec3 direction = entityOrigin.subtract(this.center).normalize();
                         boolean shouldDamageEntity = this.damageCalculator.shouldDamageEntity(this, entity);
                         float knockbackMultiplier = this.damageCalculator.getKnockbackMultiplier(entity);
-                        float exposure = !shouldDamageEntity && knockbackMultiplier == 0.0F ? 0.0F : getSeenPercent(this.center, entity);
+                        float exposure = !shouldDamageEntity && knockbackMultiplier == 0.0F ? 0.0F : this.fandSeenPercent(entity);
                         if (shouldDamageEntity) {
                             entity.hurtServer(this.level, this.damageSource, this.damageCalculator.getEntityDamageAmount(this, entity, exposure));
                         }
diff --git a/net/minecraft/world/scores/Scoreboard.java b/net/minecraft/world/scores/Scoreboard.java
index fe7c562a4944f9c96dc1476d36f136769bbe212f..b167e20095d347b6623ce28250874cca8d08740e 100644
--- a/net/minecraft/world/scores/Scoreboard.java
+++ b/net/minecraft/world/scores/Scoreboard.java
@@ -36,6 +36,14 @@ public class Scoreboard {
     private final Map<DisplaySlot, Objective> displayObjectives = new EnumMap<>(DisplaySlot.class);
     private final Object2ObjectMap<String, PlayerTeam> teamsByName = new Object2ObjectOpenHashMap<>();
     private final Object2ObjectMap<String, PlayerTeam> teamsByPlayer = new Object2ObjectOpenHashMap<>();
