@@ -266,7 +270,8 @@ public class BlockItem extends Item {
             final Map<BlockPos, io.fand.api.component.DataComponentMap> beforeComponents,
             final ServerPlayer player
     ) {
-        for (Map.Entry<BlockPos, BlockState> entry : beforeStates.entrySet()) {
+        level.getBlockTicks().clearArea(restoreArea(beforeStates));
+        for (Map.Entry<BlockPos, BlockState> entry : orderedRestoreStates(beforeStates)) {
             BlockPos pos = entry.getKey();
             level.setBlock(pos, entry.getValue(), Block.UPDATE_ALL);
             io.fand.api.component.DataComponentMap components = beforeComponents.getOrDefault(pos, io.fand.api.component.DataComponentMap.EMPTY);
@@ -279,6 +284,42 @@ public class BlockItem extends Item {
         }
     }
 
+    private static void restorePlacementIfTracked(
+            final Level level,
+            final Map<BlockPos, BlockState> beforeStates,
+            final Map<BlockPos, io.fand.api.component.DataComponentMap> beforeComponents,
+            final @Nullable Player player
+    ) {
+        if (level instanceof net.minecraft.server.level.ServerLevel serverLevel && player instanceof ServerPlayer serverPlayer && !beforeStates.isEmpty()) {
+            restorePlacement(serverLevel, beforeStates, beforeComponents, serverPlayer);
+        }
+    }
+
+    private static List<Map.Entry<BlockPos, BlockState>> orderedRestoreStates(final Map<BlockPos, BlockState> states) {
+        List<Map.Entry<BlockPos, BlockState>> ordered = new ArrayList<>(states.entrySet());
+        ordered.sort((left, right) -> Integer.compare(right.getKey().getY(), left.getKey().getY()));
+        return ordered;
+    }
+
+    private static BoundingBox restoreArea(final Map<BlockPos, BlockState> states) {
+        BlockPos first = states.keySet().iterator().next();
+        int minX = first.getX();
+        int minY = first.getY();
+        int minZ = first.getZ();
+        int maxX = first.getX();
+        int maxY = first.getY();
+        int maxZ = first.getZ();
+        for (BlockPos pos : states.keySet()) {
+            minX = Math.min(minX, pos.getX());
+            minY = Math.min(minY, pos.getY());
+            minZ = Math.min(minZ, pos.getZ());
+            maxX = Math.max(maxX, pos.getX());
+            maxY = Math.max(maxY, pos.getY());
+            maxZ = Math.max(maxZ, pos.getZ());
+        }
+        return new BoundingBox(minX, minY, minZ, maxX, maxY, maxZ);
+    }
+
     public void registerBlocks(final Map<Block, Item> map, final Item item) {
         map.put(this.getBlock(), item);
     }
