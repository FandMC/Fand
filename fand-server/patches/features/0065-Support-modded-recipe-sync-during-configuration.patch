     public void startConfiguration() {
         this.send(new ClientboundCustomPayloadPacket(new BrandPayload(this.server.getServerModName())));
+        io.fand.server.hooks.FandHooks.addPluginChannelConfigurationTask(this.configurationTasks);
         ServerLinks serverLinks = this.server.serverLinks();
         if (!serverLinks.isEmpty()) {
             this.send(new ClientboundServerLinksPacket(serverLinks.untrust()));
@@ -127,6 +131,39 @@ public class ServerConfigurationPacketListenerImpl extends ServerCommonPacketLis
         this.server.getServerResourcePack().ifPresent(info -> this.configurationTasks.add(new ServerResourcePackConfigurationTask(info)));
     }
 
+    @Override
+    public void handlePong(final ServerboundPongPacket packet) {
+        PacketUtils.ensureRunningOnSameThread(packet, this, this.server.packetProcessor());
+        ConfigurationTask task = this.currentTask;
+        if (task != null && task.handlePong(packet, this::send)) {
+            if (task.tick()) {
+                this.finishCurrentTask(task.type());
+            }
+            return;
+        }
+
+        super.handlePong(packet);
+    }
+
+    @Override
+    public void handleCustomPayload(final ServerboundCustomPayloadPacket packet) {
+        PacketUtils.ensureRunningOnSameThread(packet, this, this.server.packetProcessor());
+        ConfigurationTask task = this.currentTask;
+        if (task != null && task.handleCustomPayload(packet, this::send)) {
+            if (task.tick()) {
+                this.finishCurrentTask(task.type());
+            }
+            return;
+        }
+
+        if (packet.payload() instanceof DiscardedPayload payload
+            && io.fand.server.hooks.FandHooks.handlePluginChannelConfigurationPayload(this, payload.id(), payload.payload())) {
+            return;
+        }
+
+        super.handleCustomPayload(packet);
+    }
+
     @Override
     public void handleClientInformation(final ServerboundClientInformationPacket packet) {
         this.clientInformation = packet.information();
