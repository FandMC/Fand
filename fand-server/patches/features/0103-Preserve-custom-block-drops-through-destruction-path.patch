--- a/net/minecraft/world/level/Level.java
+++ b/net/minecraft/world/level/Level.java
@@ -281,6 +281,9 @@ public abstract class Level implements LevelAccessor, AutoCloseable {
         BlockState newState = this.getBlockState(pos);
         if (newState == blockState) {
             if (!this.isClientSide() && this instanceof net.minecraft.server.level.ServerLevel serverLevel) {
+                if (oldState.getBlock() != newState.getBlock()) {
+                    io.fand.server.hooks.FandHooks.customBlockRemoved(serverLevel, pos);
+                }
                 io.fand.server.component.BlockComponentStorage.clearIfBlockChanged(serverLevel, pos, oldState, newState);
             }
 
@@ -330,14 +333,22 @@ public abstract class Level implements LevelAccessor, AutoCloseable {
             return false;
         }
 
+        var fandCustomDrops = this instanceof net.minecraft.server.level.ServerLevel serverLevel
+            ? io.fand.server.hooks.FandHooks.customBlockDrops(serverLevel, pos)
+            : null;
+
         FluidState fluidState = this.getFluidState(pos);
         if (!(blockState.getBlock() instanceof BaseFireBlock)) {
             this.levelEvent(LevelEvent.PARTICLES_DESTROY_BLOCK, pos, Block.getId(blockState));
         }
 
         if (dropResources) {
-            BlockEntity blockEntity = blockState.hasBlockEntity() ? this.getBlockEntity(pos) : null;
-            Block.dropResources(blockState, this, pos, blockEntity, breaker, ItemStack.EMPTY);
+            if (fandCustomDrops == null) {
+                BlockEntity blockEntity = blockState.hasBlockEntity() ? this.getBlockEntity(pos) : null;
+                Block.dropResources(blockState, this, pos, blockEntity, breaker, ItemStack.EMPTY);
+            } else {
+                fandCustomDrops.forEach(drop -> Block.popResource(this, pos, drop));
+            }
         }
 
         boolean destroyed = this.setBlock(pos, fluidState.createLegacyBlock(), Block.UPDATE_ALL, updateLimit);
