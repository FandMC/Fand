+    public LevelStem fand$voidLevelStem(final ResourceKey<LevelStem> template) {
+        Registry<LevelStem> dimensions = this.registries.compositeAccess().lookupOrThrow(Registries.LEVEL_STEM);
+        LevelStem base = dimensions.getValue(template);
+        if (base == null) {
+            throw new IllegalArgumentException("World template is not available: " + template.identifier());
+        }
+        var biomes = this.registryAccess().lookupOrThrow(Registries.BIOME);
+        var structureSets = this.registryAccess().lookupOrThrow(Registries.STRUCTURE_SET);
+        var placedFeatures = this.registryAccess().lookupOrThrow(Registries.PLACED_FEATURE);
+        var flat = FlatLevelGeneratorSettings.getDefault(biomes, structureSets, placedFeatures)
+            .withBiomeAndLayers(java.util.List.of(new FlatLayerInfo(1, net.minecraft.world.level.block.Blocks.AIR)), Optional.empty(), biomes.getOrThrow(net.minecraft.world.level.biome.Biomes.THE_VOID));
+        return new LevelStem(base.type(), new FlatLevelSource(flat));
+    }
