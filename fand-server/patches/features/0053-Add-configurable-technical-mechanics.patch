+++ b/net/minecraft/world/entity/projectile/ThrowableProjectile.java
@@ -45,6 +45,25 @@ public abstract class ThrowableProjectile extends Projectile {
     @Override
     public void tick() {
         this.handleFirstTickBubbleColumn();
+        if (io.fand.server.hooks.FandHooks.oldThrowableProjectileTickOrderEnabled()) {
+            super.tick();
+            HitResult result = ProjectileUtil.getHitResultOnMoveVector(this, this::canHitEntity);
+            if (result.getType() != HitResult.Type.MISS) {
+                this.hitTargetOrDeflectSelf(result);
+            }
+
+            Vec3 movement = this.getDeltaMovement();
+            double x = this.getX() + movement.x;
+            double y = this.getY() + movement.y;
+            double z = this.getZ() + movement.z;
+            this.updateRotation();
+            this.applyInertia();
+            this.applyGravity();
+            this.setPos(x, y, z);
+            this.applyEffectsFromBlocks();
+            return;
+        }
+
         this.applyGravity();
         this.applyInertia();
         HitResult result = ProjectileUtil.getHitResultOnMoveVector(this, this::canHitEntity);
