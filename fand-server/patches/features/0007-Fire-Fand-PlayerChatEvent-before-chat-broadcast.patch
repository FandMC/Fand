From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: fand <fand@local>
Date: Fri, 5 Jun 2026 17:25:55 +0800
Subject: [PATCH] Fire Fand PlayerChatEvent before chat broadcast


diff --git a/net/minecraft/server/network/ServerGamePacketListenerImpl.java b/net/minecraft/server/network/ServerGamePacketListenerImpl.java
index 1fed7e2103bbca99770c5411314a7c25441a58d8..8d53467519f0c1a85bb358ad02f113ac058072d9 100644
--- a/net/minecraft/server/network/ServerGamePacketListenerImpl.java
+++ b/net/minecraft/server/network/ServerGamePacketListenerImpl.java
@@ -1525,7 +1525,30 @@ public class ServerGamePacketListenerImpl
                 CompletableFuture<FilteredText> filteredFuture = this.filterTextPacket(signedMessage.signedContent());
                 Component decorated = this.server.getChatDecorator().decorate(this.player, signedMessage.decoratedContent());
                 this.chatMessageChain.append(filteredFuture, filtered -> {
-                    PlayerChatMessage filteredMessage = signedMessage.withUnsignedContent(decorated).filter(filtered.mask());
+                    var fandPlayer = io.fand.server.Main.runtime().playerRegistry().find(this.player.getUUID()).orElse(null);
+                    Component fandDecorated = decorated;
+                    if (fandPlayer != null) {
+                        net.kyori.adventure.text.Component fandMessage;
+                        try {
+                            fandMessage = io.fand.server.command.AdventureBridge.fromVanilla(decorated, this.player.registryAccess());
+                        } catch (RuntimeException fandFailure) {
+                            LOGGER.warn("Skipping PlayerChatEvent after fromVanilla failure", fandFailure);
+                            fandMessage = null;
+                        }
+                        if (fandMessage != null) {
+                            var fandChatEvent = new io.fand.api.event.player.PlayerChatEvent(fandPlayer, packet.message(), fandMessage);
+                            try {
+                                io.fand.server.Main.runtime().events().fire(fandChatEvent);
+                            } catch (RuntimeException fandFailure) {
+                                LOGGER.warn("PlayerChatEvent listener failed", fandFailure);
+                            }
+                            if (fandChatEvent.cancelled()) {
+                                return;
+                            }
+                            fandDecorated = io.fand.server.command.AdventureBridge.toVanillaOrFallback(fandChatEvent.message(), decorated, this.player.registryAccess());
+                        }
+                    }
+                    PlayerChatMessage filteredMessage = signedMessage.withUnsignedContent(fandDecorated).filter(filtered.mask());
                     this.broadcastChatMessage(filteredMessage);
                 });
             });
