+    protected static boolean canPushMinecart(final AbstractMinecart receiver, final AbstractMinecart pushed) {
+        if (receiver.level().isClientSide() || pushed.noPhysics || receiver.noPhysics || receiver.hasPassenger(pushed)) {
+            return false;
+        }
+
+        double xa = pushed.getX() - receiver.getX();
+        double za = pushed.getZ() - receiver.getZ();
