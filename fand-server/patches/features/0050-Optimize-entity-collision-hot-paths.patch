+    public <T extends Entity> AbortableIterationConsumer.Continuation forEachEntity(
+        final EntityTypeTest<Entity, T> type,
+        final AABB bb,
+        final Predicate<? super T> selector,
+        final AbortableIterationConsumer<T> consumer
+    ) {
+        Profiler.get().incrementCounter("getEntities");
+        boolean includeDragonParts = canTypeMatchDragonPart(type);
+        return this.getEntities().get(type, bb, e -> {
+            if (selector.test(e) && consumer.accept(e).shouldAbort()) {
+                return AbortableIterationConsumer.Continuation.ABORT;
+            }
+
+            if (includeDragonParts && e instanceof EnderDragon enderDragon) {
+                for (EnderDragonPart subEntity : enderDragon.getSubEntities()) {
+                    T castSubPart = type.tryCast(subEntity);
+                    if (castSubPart != null && selector.test(castSubPart) && consumer.accept(castSubPart).shouldAbort()) {
+                        return AbortableIterationConsumer.Continuation.ABORT;
+                    }
+                }
+            }
+
+            return AbortableIterationConsumer.Continuation.CONTINUE;
+        });
+    }
