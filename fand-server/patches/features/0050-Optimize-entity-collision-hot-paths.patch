+    private static Iterable<VoxelShape> collectCollidersIterable(
+        final @Nullable Entity source, final Level level, final List<VoxelShape> entityColliders, final AABB boundingBox
+    ) {
+        Iterable<VoxelShape> blockColliders = level.getBlockCollisions(source, boundingBox);
+        WorldBorder worldBorder = level.getWorldBorder();
+        boolean isEntityInsideCloseToBorder = source != null && worldBorder.isInsideCloseToBorder(source, boundingBox);
+        if (isEntityInsideCloseToBorder) {
+            Iterable<VoxelShape> borderCollider = List.of(worldBorder.getCollisionShape());
+            return entityColliders.isEmpty()
+                ? Iterables.concat(borderCollider, blockColliders)
+                : Iterables.concat(entityColliders, borderCollider, blockColliders);
+        }
+        return entityColliders.isEmpty() ? blockColliders : Iterables.concat(entityColliders, blockColliders);
+    }
+
+    private static boolean hasSingleAxisMovement(final Vec3 movement) {
+        int axes = 0;
+        if (movement.x != 0.0) {
+            axes++;
+        }
+        if (movement.y != 0.0) {
+            axes++;
+        }
+        if (movement.z != 0.0) {
+            axes++;
+        }
+        return axes == 1;
+    }
+
