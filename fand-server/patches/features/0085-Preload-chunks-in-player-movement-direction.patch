+    private void updateMovementPreload(final ServerPlayer player) {
+        Vec3 movement = player.getDeltaMovement();
+        this.updateMovementPreload(player, player.getX() - movement.x, player.getZ() - movement.z);
+    }
+
+    private void updateMovementPreload(final ServerPlayer player, final double oldX, final double oldZ) {
+        if (!io.fand.server.hooks.FandHooks.chunkMovementPreloadEnabled() || this.skipPlayer(player)) {
+            this.clearMovementPreload(player);
+            return;
+        }
+
+        double dx = player.getX() - oldX;
+        double dz = player.getZ() - oldZ;
+        double minDistance = io.fand.server.hooks.FandHooks.chunkMovementPreloadMinHorizontalDistanceBlocks();
+        double distanceSqr = dx * dx + dz * dz;
+        if (distanceSqr < minDistance * minDistance) {
+            LongSet previous = this.fandMovementPreloadByPlayer.get(player.getUUID());
+            if (previous != null && !previous.isEmpty()) {
+                this.refreshMovementPreloadTickets(previous);
+            }
+            return;
+        }
+
+        LongSet next = this.buildMovementPreloadChunks(player, dx, dz);
+        this.applyMovementPreload(player, next);
+    }
+
+    private LongSet buildMovementPreloadChunks(final ServerPlayer player, final double dx, final double dz) {
+        int lookahead = io.fand.server.hooks.FandHooks.chunkMovementPreloadLookaheadChunks();
+        int width = io.fand.server.hooks.FandHooks.chunkMovementPreloadWidthChunks();
+        if (lookahead <= 0) {
+            return new LongOpenHashSet();
+        }
+
+        double length = Math.sqrt(dx * dx + dz * dz);
+        if (length < 1.0E-6) {
+            return new LongOpenHashSet();
+        }
+
+        int viewDistance = this.getPlayerViewDistance(player);
+        ChunkPos center = player.chunkPosition();
+        double forwardX = dx / length;
+        double forwardZ = dz / length;
+        double sideX = -forwardZ;
+        double sideZ = forwardX;
+        LongLinkedOpenHashSet chunks = new LongLinkedOpenHashSet();
+        for (int forward = viewDistance + 1; forward <= viewDistance + lookahead; forward++) {
+            this.addMovementPreloadColumn(chunks, center, viewDistance, forwardX, forwardZ, sideX, sideZ, forward, width);
+        }
+
+        return chunks;
+    }
+
+    private void addMovementPreloadColumn(
+        final LongLinkedOpenHashSet chunks,
+        final ChunkPos center,
+        final int viewDistance,
+        final double forwardX,
+        final double forwardZ,
+        final double sideX,
+        final double sideZ,
+        final int forward,
+        final int width
+    ) {
+        for (int side = 0; side <= width; side++) {
+            if (side == 0) {
+                this.addMovementPreloadChunk(chunks, center, viewDistance, forwardX, forwardZ, sideX, sideZ, forward, 0);
+            } else {
+                this.addMovementPreloadChunk(chunks, center, viewDistance, forwardX, forwardZ, sideX, sideZ, forward, side);
+                this.addMovementPreloadChunk(chunks, center, viewDistance, forwardX, forwardZ, sideX, sideZ, forward, -side);
+            }
+        }
+    }
+
+    private void addMovementPreloadChunk(
+        final LongLinkedOpenHashSet chunks,
+        final ChunkPos center,
+        final int viewDistance,
+        final double forwardX,
+        final double forwardZ,
+        final double sideX,
+        final double sideZ,
+        final int forward,
+        final int side
+    ) {
+        int chunkX = center.x() + Mth.floor(forwardX * forward + sideX * side + 0.5);
+        int chunkZ = center.z() + Mth.floor(forwardZ * forward + sideZ * side + 0.5);
+        if (ChunkPos.isValid(chunkX, chunkZ) && !ChunkTrackingView.isInViewDistance(center.x(), center.z(), viewDistance, chunkX, chunkZ)) {
+            chunks.add(ChunkPos.pack(chunkX, chunkZ));
+        }
+    }
+
+    private void applyMovementPreload(final ServerPlayer player, final LongSet next) {
+        UUID playerId = player.getUUID();
+        LongSet previous = this.fandMovementPreloadByPlayer.get(playerId);
+        if (previous == null) {
+            previous = new LongOpenHashSet();
+        }
+
+        LongIterator previousIterator = previous.iterator();
+        while (previousIterator.hasNext()) {
+            long chunkPos = previousIterator.nextLong();
+            if (!next.contains(chunkPos)) {
+                this.releaseMovementPreload(chunkPos);
+            }
+        }
+
+        LongIterator nextIterator = next.iterator();
+        while (nextIterator.hasNext()) {
+            long chunkPos = nextIterator.nextLong();
+            if (previous.contains(chunkPos)) {
+                this.refreshMovementPreloadTicket(chunkPos);
+            } else {
+                this.retainMovementPreload(chunkPos);
+            }
+        }
+
+        if (next.isEmpty()) {
+            this.fandMovementPreloadByPlayer.remove(playerId);
+        } else {
+            this.fandMovementPreloadByPlayer.put(playerId, next);
+        }
+    }
+
+    private void retainMovementPreload(final long chunkPos) {
+        int references = this.fandMovementPreloadRefs.addTo(chunkPos, 1);
+        if (references == 0) {
+            this.ticketStorage.addTicket(chunkPos, movementPreloadTicket());
+            this.scheduleMovementPreloadGeneration(chunkPos);
+        } else {
+            this.refreshMovementPreloadTicket(chunkPos);
+        }
+    }
+
+    private void releaseMovementPreload(final long chunkPos) {
+        int references = this.fandMovementPreloadRefs.get(chunkPos);
+        if (references <= 1) {
+            this.fandMovementPreloadRefs.remove(chunkPos);
+            this.fandMovementPreloadGenerationQueue.remove(chunkPos);
+            this.ticketStorage.removeTicket(chunkPos, movementPreloadTicket());
+        } else {
+            this.fandMovementPreloadRefs.put(chunkPos, references - 1);
+        }
+    }
+
+    private void clearMovementPreload(final ServerPlayer player) {
+        LongSet previous = this.fandMovementPreloadByPlayer.remove(player.getUUID());
+        if (previous == null) {
+            return;
+        }
+
+        LongIterator iterator = previous.iterator();
+        while (iterator.hasNext()) {
+            this.releaseMovementPreload(iterator.nextLong());
+        }
+    }
+
+    private void refreshMovementPreloadTickets(final LongSet chunks) {
+        LongIterator iterator = chunks.iterator();
+        while (iterator.hasNext()) {
+            this.refreshMovementPreloadTicket(iterator.nextLong());
+        }
+    }
+
+    private void refreshMovementPreloadTicket(final long chunkPos) {
+        this.ticketStorage.addTicket(chunkPos, movementPreloadTicket());
+    }
+
+    private void scheduleMovementPreloadGeneration(final long chunkPos) {
+        this.fandMovementPreloadGenerationQueue.add(chunkPos);
+    }
+
+    private static Ticket movementPreloadTicket() {
+        return new Ticket(TicketType.MOVEMENT_PRELOAD, FAND_MOVEMENT_PRELOAD_TICKET_LEVEL);
+    }
+
     private AABB playerTrackingRange(final ServerPlayer player, final double x, final double y, final double z) {
         double range = Math.max(this.level.getServer().getScaledTrackingDistance(player.getType().clientTrackingRange() * 16), this.getPlayerViewDistance(player) * 16.0);
         return new AABB(x - range, this.level.getMinY(), z - range, x + range, this.level.getMaxY(), z + range);
