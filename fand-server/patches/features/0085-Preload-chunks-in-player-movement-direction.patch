+    private void runMovementPreloadGeneration() {
+        int budget = Math.max(64, io.fand.server.hooks.FandHooks.chunkWorldgenParallelism() * 8);
+        while (budget-- > 0 && !this.fandMovementPreloadGenerationQueue.isEmpty()) {
+            long chunkPos = this.fandMovementPreloadGenerationQueue.removeFirstLong();
+            if (!this.fandMovementPreloadRefs.containsKey(chunkPos)) {
+                continue;
+            }
+
+            ChunkHolder holder = this.updatingChunkMap.get(chunkPos);
+            if (holder != null) {
+                holder.scheduleChunkGenerationTask(ChunkStatus.FULL, this);
+            }
+        }
+    }
