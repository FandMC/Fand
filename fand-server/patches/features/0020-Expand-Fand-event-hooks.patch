     }
 
+    private static void registerMinecraftNamespaceAliases(final CommandDispatcher<CommandSourceStack> dispatcher) {
+        RootCommandNode<CommandSourceStack> root = dispatcher.getRoot();
+        for (CommandNode<CommandSourceStack> child : java.util.List.copyOf(root.getChildren())) {
+            if (!(child instanceof LiteralCommandNode<?>)) {
+                continue;
+            }
+            @SuppressWarnings("unchecked")
+            LiteralCommandNode<CommandSourceStack> literal = (LiteralCommandNode<CommandSourceStack>) child;
+            String name = literal.getLiteral();
+            if (name.indexOf(':') >= 0) {
+                continue;
+            }
+            String namespaced = "minecraft:" + name;
+            if (root.getChild(namespaced) != null) {
+                continue;
+            }
+            root.addChild(copyLiteral(namespaced, literal));
+        }
+    }
+
+    private static <S> LiteralCommandNode<S> copyLiteral(final String name, final LiteralCommandNode<S> source) {
+        LiteralArgumentBuilder<S> builder = LiteralArgumentBuilder.<S>literal(name)
+            .requires(source.getRequirement())
+            .forward(source.getRedirect(), source.getRedirectModifier(), source.isFork());
+        if (source.getCommand() != null) {
+            builder.executes(source.getCommand());
+        }
+        for (CommandNode<S> child : source.getChildren()) {
+            builder.then(child);
+        }
+        return builder.build();
+    }
+
