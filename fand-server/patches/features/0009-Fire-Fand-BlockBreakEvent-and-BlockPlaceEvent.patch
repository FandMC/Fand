diff --git a/net/minecraft/server/level/ServerPlayerGameMode.java b/net/minecraft/server/level/ServerPlayerGameMode.java
index c770612524a09bdd624679bbec1d72d7016cc556..4f38ac40b1e702a3e77be1fbc6f3055a95c0cc74 100644
--- a/net/minecraft/server/level/ServerPlayerGameMode.java
+++ b/net/minecraft/server/level/ServerPlayerGameMode.java
@@ -272,6 +272,26 @@ public class ServerPlayerGameMode {
             } else if (this.player.blockActionRestricted(this.level, pos, this.gameModeForPlayer)) {
                 return false;
             } else {
+                if (io.fand.server.Main.runtime().events().hasListeners(io.fand.api.event.block.BlockBreakEvent.class)) {
+                    var fandPlayer = io.fand.server.Main.runtime().playerRegistry().find(this.player.getUUID()).orElse(null);
+                    if (fandPlayer != null) {
+                        var fandWorld = io.fand.server.Main.runtime().worldRegistry().map(r -> r.wrap(this.level)).orElse(null);
+                        if (fandWorld != null) {
+                            var fandBlock = new io.fand.server.block.FandBlock(fandWorld, pos.getX(), pos.getY(), pos.getZ());
+                            var fandBlockType = io.fand.server.block.FandBlockType.of(block);
+                            var fandBreakEvent = new io.fand.api.event.block.BlockBreakEvent(fandPlayer, fandBlock, fandBlockType);
+                            try {
+                                io.fand.server.Main.runtime().events().fire(fandBreakEvent);
+                            } catch (RuntimeException fandFailure) {
+                                LOGGER.warn("BlockBreakEvent listener failed", fandFailure);
+                            }
+                            if (fandBreakEvent.cancelled()) {
+                                this.level.sendBlockUpdated(pos, state, state, Block.UPDATE_ALL);
+                                return false;
+                            }
+                        }
+                    }
+                }
                 BlockState adjustedState = block.playerWillDestroy(this.level, pos, state, this.player);
                 boolean changed = this.level.removeBlock(pos, false);
                 if (SharedConstants.DEBUG_BLOCK_BREAK) {
