+    private static Map<Long, File> selectSourceFiles(final File[] files) {
+        Map<Long, File> sourceFiles = new LinkedHashMap<>();
+        RegionFileFormat selectedFormat = RegionFileFormat.getSelected();
+
+        for (File file : files) {
+            RegionFileFormat.RegionFileName fileName = RegionFileFormat.parseRegionFileName(file.getName());
+            if (fileName == null) {
+                continue;
+            }
+
+            long key = ChunkPos.pack(fileName.regionX(), fileName.regionZ());
+            File existingFile = sourceFiles.get(key);
+            if (existingFile == null) {
+                sourceFiles.put(key, file);
+                continue;
+            }
+
+            RegionFileFormat.RegionFileName existingFileName = RegionFileFormat.parseRegionFileName(existingFile.getName());
+            if (existingFileName != null && existingFileName.format() != selectedFormat && fileName.format() == selectedFormat) {
+                sourceFiles.put(key, file);
+            }
+        }
+
+        return sourceFiles;
+    }
