+package net.minecraft.world.level.chunk.storage;
+
+import com.mojang.logging.LogUtils;
+import java.io.IOException;
+import java.nio.file.Path;
+import java.util.Arrays;
+import java.util.Locale;
+import java.util.regex.Matcher;
+import java.util.regex.Pattern;
+import org.jspecify.annotations.Nullable;
+import org.slf4j.Logger;
+
+public enum RegionFileFormat {
+    MCA("mca", RegionFileStorage.ANVIL_EXTENSION) {
+        @Override
+        public RegionFileAccess create(final RegionStorageInfo info, final Path path, final Path folder, final boolean sync) throws IOException {
+            return new RegionFile(info, path, folder, sync);
+        }
+    },
+    FLR("flr", RegionFileStorage.FAND_LINEAR_EXTENSION) {
+        @Override
+        public RegionFileAccess create(final RegionStorageInfo info, final Path path, final Path folder, final boolean sync) throws IOException {
+            return new FandLinearRegionFile(info, path, sync);
+        }
+    };
+
+    private static final Logger LOGGER = LogUtils.getLogger();
+    private static final Pattern REGION_FILE_PATTERN = Pattern.compile("^r\\.(-?[0-9]+)\\.(-?[0-9]+)\\.(mca|flr)$");
+    private static volatile RegionFileFormat selected = MCA;
+    private final String optionName;
+    private final String extension;
+
+    RegionFileFormat(final String optionName, final String extension) {
+        this.optionName = optionName;
+        this.extension = extension;
+    }
+
+    public abstract RegionFileAccess create(RegionStorageInfo info, Path path, Path folder, boolean sync) throws IOException;
+
+    public static void configure(final String optionName) {
+        RegionFileFormat format = byName(optionName);
+        if (format != null) {
+            selected = format;
+        } else {
+            LOGGER.error(
+                "Invalid `region-file-format` value `{}` in server.properties. Please use one of: {}",
+                optionName,
+                String.join(", ", Arrays.stream(values()).map(RegionFileFormat::optionName).toList())
+            );
+        }
+    }
+
+    public static RegionFileFormat getSelected() {
+        return selected;
+    }
+
+    public static @Nullable RegionFileFormat byName(final String optionName) {
+        String normalizedName = optionName.toLowerCase(Locale.ROOT);
+        for (RegionFileFormat format : values()) {
+            if (format.optionName.equals(normalizedName)) {
+                return format;
+            }
+        }
+
+        return null;
+    }
+
+    public static @Nullable RegionFileName parseRegionFileName(final String name) {
+        Matcher matcher = REGION_FILE_PATTERN.matcher(name);
+        if (!matcher.matches()) {
+            return null;
+        }
+
+        RegionFileFormat format = byName(matcher.group(3));
+        if (format == null) {
+            return null;
+        }
+
+        return new RegionFileName(Integer.parseInt(matcher.group(1)), Integer.parseInt(matcher.group(2)), format);
+    }
+
+    public String optionName() {
+        return this.optionName;
+    }
+
+    public String extension() {
+        return this.extension;
+    }
+
+    public String getRegionFileName(final int regionX, final int regionZ) {
+        return "r." + regionX + "." + regionZ + this.extension;
+    }
+
+    public record RegionFileName(int regionX, int regionZ, RegionFileFormat format) {
+    }
+}
