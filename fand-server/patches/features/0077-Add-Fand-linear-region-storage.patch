+                FileUtil.createDirectoriesSafe(targetFile.getParent());
+                Files.deleteIfExists(targetFile);
+
+                try (FandLinearRegionFile regionFile = new FandLinearRegionFile(storage.writeInfo(), targetFile, false)) {
+                    regionFile.writeCompressedChunks(chunks);
+                }
+            } catch (IOException e) {
+                throw new UncheckedIOException("Failed to batch write linear region file " + fileToUpgrade.file(), e);
+            }
+        }
+
+        return converted;
+    }
+
+    private FandLinearRegionFile.CompressedChunk compressChunk(final CompoundTag chunkTag) throws IOException {
+        RegionFileVersion version = RegionFileVersion.getSelected();
+        ByteArrayOutputStream bytes = new ByteArrayOutputStream(8192);
+
+        try (DataOutputStream output = new DataOutputStream(version.wrap(bytes))) {
+            NbtIo.write(chunkTag, output);
+        }
+
+        return new FandLinearRegionFile.CompressedChunk(bytes.toByteArray(), version);
     }
 
