+    private boolean processOneFileToLinearRegion(final RecreatingSimpleRegionStorage storage, final FileToUpgrade fileToUpgrade) {
+        Map<ChunkPos, FandLinearRegionFile.CompressedChunk> chunks = new LinkedHashMap<>();
+        boolean converted = true;
+
+        try (RegionFileAccess sourceRegion = fileToUpgrade.sourceFormat().create(storage.storageInfo(), fileToUpgrade.file(), fileToUpgrade.file().getParent(), false)) {
+            for (ChunkPos chunkPos : fileToUpgrade.chunksToUpgrade()) {
+                try (DataInputStream input = sourceRegion.getChunkDataInputStream(chunkPos)) {
+                    CompoundTag chunkTag = input == null ? null : NbtIo.read(input);
+                    CompoundTag upgradedTag = this.createUpgradedChunkTag(storage, chunkPos, chunkTag);
+                    if (upgradedTag == null) {
+                        converted = false;
+                        this.upgradeProgress.incrementSkipped();
+                        continue;
+                    }
+
+                    chunks.put(chunkPos, this.compressChunk(upgradedTag));
+                    this.upgradeProgress.incrementConverted();
+                } catch (ReportedException | CompletionException e) {
+                    Throwable cause = e.getCause();
+                    if (!(cause instanceof IOException)) {
+                        throw e;
+                    }
+
+                    LOGGER.error("Error upgrading chunk {}", chunkPos, cause);
+                    converted = false;
+                    this.upgradeProgress.incrementSkipped();
+                } catch (IOException e) {
+                    LOGGER.error("Error upgrading chunk {}", chunkPos, e);
+                    converted = false;
+                    this.upgradeProgress.incrementSkipped();
+                }
+            }
+        } catch (IOException e) {
