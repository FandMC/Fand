diff --git a/net/minecraft/server/level/FandAsyncChunkSystem.java b/net/minecraft/server/level/FandAsyncChunkSystem.java
new file mode 100644
index 0000000000000000000000000000000000000000..4ba0cdbe3adbc5a83d0736da470417e95b4f5b67
--- /dev/null
+++ b/net/minecraft/server/level/FandAsyncChunkSystem.java
@@ -0,0 +1,171 @@
+package net.minecraft.server.level;
+
+import com.google.common.annotations.VisibleForTesting;
+import java.util.ArrayDeque;
+import java.util.ArrayList;
+import java.util.List;
+import java.util.concurrent.CompletableFuture;
+import net.minecraft.world.level.ChunkPos;
+import net.minecraft.world.level.chunk.status.ChunkStatus;
+import org.jspecify.annotations.Nullable;
+
+/**
+ * Fand-owned async chunk generation control plane.
+ *
+ * <p>ChunkHolder remains the source of ticket/future truth for now, but task
+ * queuing, wakeups, and execution dispatch are intentionally kept out of
+ * ChunkMap so the scheduler can grow into a region-aware task graph.
+ */
+final class FandAsyncChunkSystem {
+    private final GeneratingChunkMap chunkMap;
+    private final ChunkTaskDispatcher worldgenTaskDispatcher;
+    private final @Nullable RegionizedChunkTaskScheduler regionizedTaskScheduler;
+    private final List<ArrayDeque<FandAsyncChunkSystem.TaskHandle>> readyTasksByLane;
+    private final boolean[] activeTasksByLane;
+    private int readyTaskCount;
+    private int nextDrainLane;
+
+    FandAsyncChunkSystem(
+        final GeneratingChunkMap chunkMap,
+        final ChunkTaskDispatcher worldgenTaskDispatcher,
+        final @Nullable RegionizedChunkTaskScheduler regionizedTaskScheduler
+    ) {
+        this.chunkMap = chunkMap;
+        this.worldgenTaskDispatcher = worldgenTaskDispatcher;
+        this.regionizedTaskScheduler = regionizedTaskScheduler;
+        int laneCount = regionizedTaskScheduler == null ? 1 : regionizedTaskScheduler.laneCount();
+        this.readyTasksByLane = new ArrayList<>(laneCount);
+        this.activeTasksByLane = new boolean[laneCount];
+        for (int lane = 0; lane < laneCount; lane++) {
+            this.readyTasksByLane.add(new ArrayDeque<>());
+        }
+    }
+
+    ChunkGenerationTask scheduleGenerationTask(final ChunkStatus targetStatus, final ChunkPos pos) {
+        ChunkGenerationTask task = ChunkGenerationTask.create(this.chunkMap, targetStatus, pos);
+        this.enqueueReadyTask(new ChunkGenerationTaskHandle(task), pos.pack());
+        return task;
+    }
+
+    void runGenerationTasks() {
+        List<ScheduledTask> tasks = this.drainReadyTasks();
+
+        for (ScheduledTask task : tasks) {
+            this.dispatchTask(task);
+        }
+    }
+
+    private void dispatchTask(final ScheduledTask scheduledTask) {
+        GenerationChunkHolder chunk = scheduledTask.task().center();
+        this.worldgenTaskDispatcher.submit(() -> this.advanceTask(scheduledTask), chunk.getPos().pack(), chunk::getQueueLevel);
+    }
+
+    private void advanceTask(final ScheduledTask scheduledTask) {
+        TaskHandle task = scheduledTask.task();
+        CompletableFuture<?> waitingFor;
+        try {
+            waitingFor = task.runUntilWait();
+        } catch (Throwable throwable) {
+            this.releaseLaneAndRunReadyTasks(scheduledTask.lane());
+            throw throwable;
+        }
+
+        if (waitingFor != null) {
+            this.releaseLaneAndRunReadyTasks(scheduledTask.lane());
+            waitingFor.thenRun(() -> {
+                this.enqueueReadyTask(task, task.pos().pack());
+                this.runGenerationTasks();
+            });
+        } else {
+            this.releaseLaneAndRunReadyTasks(scheduledTask.lane());
+        }
+    }
+
+    private void enqueueReadyTask(final TaskHandle task, final long chunkPos) {
+        synchronized (this.readyTasksByLane) {
+            this.readyTasksByLane.get(this.laneIndex(chunkPos)).addLast(task);
+            this.readyTaskCount++;
+        }
+    }
+
+    @VisibleForTesting
+    void enqueueReadyTaskForTesting(final TaskHandle task, final long chunkPos) {
+        this.enqueueReadyTask(task, chunkPos);
+    }
+
+    private List<ScheduledTask> drainReadyTasks() {
+        synchronized (this.readyTasksByLane) {
+            if (this.readyTaskCount == 0) {
+                return List.of();
+            }
+
+            List<ScheduledTask> tasks = new ArrayList<>(this.readyTasksByLane.size());
+            while (this.readyTaskCount > 0) {
+                ScheduledTask task = this.pollNextReadyTask();
+                if (task == null) {
+                    break;
+                }
+                tasks.add(task);
+            }
+            return tasks;
+        }
+    }
+
+    private @Nullable ScheduledTask pollNextReadyTask() {
+        for (int offset = 0; offset < this.readyTasksByLane.size(); offset++) {
+            int lane = (this.nextDrainLane + offset) % this.readyTasksByLane.size();
+            if (this.activeTasksByLane[lane]) {
+                continue;
+            }
+            TaskHandle task = this.readyTasksByLane.get(lane).pollFirst();
+            if (task != null) {
+                this.activeTasksByLane[lane] = true;
+                this.readyTaskCount--;
+                this.nextDrainLane = (lane + 1) % this.readyTasksByLane.size();
+                return new ScheduledTask(task, lane);
+            }
+        }
+
+        return null;
+    }
+
+    private void releaseLaneAndRunReadyTasks(final int lane) {
+        synchronized (this.readyTasksByLane) {
+            this.activeTasksByLane[lane] = false;
+        }
+        this.runGenerationTasks();
+    }
+
+    private int laneIndex(final long chunkPos) {
+        return this.regionizedTaskScheduler == null ? 0 : this.regionizedTaskScheduler.laneIndex(chunkPos);
+    }
+
+    @VisibleForTesting
+    interface TaskHandle {
+        ChunkPos pos();
+
+        GenerationChunkHolder center();
+
+        @Nullable CompletableFuture<?> runUntilWait();
+    }
+
+    private record ChunkGenerationTaskHandle(ChunkGenerationTask task) implements TaskHandle {
+        @Override
+        public ChunkPos pos() {
+            return this.task.getPos();
+        }
+
+        @Override
+        public GenerationChunkHolder center() {
+            return this.task.getCenter();
+        }
+
+        @Override
+        public @Nullable CompletableFuture<?> runUntilWait() {
+            return this.task.runUntilWait();
+        }
+    }
+
+    private record ScheduledTask(TaskHandle task, int lane) {
+    }
+}
