From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: MC20018 <winme2001@outlook.com>
Date: Sun, 7 Jun 2026 21:55:40 +0800
Subject: [PATCH] Preserve Fand block component lifecycle


diff --git a/net/minecraft/world/item/BlockItem.java b/net/minecraft/world/item/BlockItem.java
index 7f3ae828350b5eb13a44abf5336b89560c231868..5f8b834f6bae90f7a3fa2178cb3e71241f2ed330 100644
--- a/net/minecraft/world/item/BlockItem.java
+++ b/net/minecraft/world/item/BlockItem.java
@@ -68,6 +68,9 @@ public class BlockItem extends Item {
         Level level = updatedPlaceContext.getLevel();
         Player player = updatedPlaceContext.getPlayer();
         BlockState replacedState = level.getBlockState(pos);
+        io.fand.api.component.DataComponentMap replacedComponents = level instanceof net.minecraft.server.level.ServerLevel serverLevel
+            ? io.fand.server.component.BlockComponentStorage.snapshot(serverLevel, pos)
+            : io.fand.api.component.DataComponentMap.EMPTY;
         if (!this.placeBlock(updatedPlaceContext, placementState)) {
             return InteractionResult.FAIL;
         }
@@ -88,6 +91,9 @@ public class BlockItem extends Item {
                             "BlockPlaceEvent");
                     if (fandPlaceEvent.cancelled()) {
                         level.setBlock(pos, replacedState, Block.UPDATE_ALL);
+                        if (!replacedComponents.isEmpty()) {
+                            io.fand.server.component.BlockComponentStorage.put(serverLevel, pos, replacedComponents);
+                        }
                         serverPlayer.connection.send(new net.minecraft.network.protocol.game.ClientboundBlockUpdatePacket(level, pos));
                         return InteractionResult.FAIL;
                     }
diff --git a/net/minecraft/world/level/Level.java b/net/minecraft/world/level/Level.java
index b89e98b3ecb529b6f2ebd9c6b27a0ee349c61ccf..6886aaef58a66f7e9404c4a7e896c7711784dbb1 100644
--- a/net/minecraft/world/level/Level.java
+++ b/net/minecraft/world/level/Level.java
@@ -239,6 +239,10 @@ public abstract class Level implements LevelAccessor, AutoCloseable {
 
         BlockState newState = this.getBlockState(pos);
         if (newState == blockState) {
+            if (!this.isClientSide() && this instanceof net.minecraft.server.level.ServerLevel serverLevel) {
+                io.fand.server.component.BlockComponentStorage.clearIfBlockChanged(serverLevel, pos, oldState, newState);
+            }
+
             if (oldState != newState) {
                 this.setBlocksDirty(pos, oldState, newState);
             }
