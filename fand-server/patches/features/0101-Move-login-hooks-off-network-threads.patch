+    private @Nullable InetAddress authenticationAddress() {
+        return this.server.getPreventProxyConnections()
+                && this.connection.getRemoteAddress() instanceof InetSocketAddress inetSocketAddress
+            ? inetSocketAddress.getAddress()
+            : null;
+    }
+
+    private void runAuthenticator(final Runnable task) {
+        Thread thread = new Thread(task, "User Authenticator #" + UNIQUE_THREAD_ID.incrementAndGet());
         thread.setUncaughtExceptionHandler(new DefaultUncaughtExceptionHandler(LOGGER));
         thread.start();
     }
