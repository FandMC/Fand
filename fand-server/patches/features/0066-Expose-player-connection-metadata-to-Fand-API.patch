Subject: [PATCH] Expose player connection metadata to Fand API


diff --git a/net/minecraft/server/network/ServerCommonPacketListenerImpl.java b/net/minecraft/server/network/ServerCommonPacketListenerImpl.java
index 0eed222b397a6ca71501f78e6ff107dea461b0da..4ccbcad52beb704b469bddd3f5fbd249efc45e09 100644
--- a/net/minecraft/server/network/ServerCommonPacketListenerImpl.java
+++ b/net/minecraft/server/network/ServerCommonPacketListenerImpl.java
@@ -196,6 +196,10 @@ public abstract class ServerCommonPacketListenerImpl implements ServerCommonPack
         this.server.executeBlocking(this.connection::handleDisconnection);
     }
 
+    public @Nullable DisconnectionDetails fand$disconnectionDetails() {
+        return this.connection.getDisconnectionDetails();
+    }
+
     protected boolean isSingleplayerOwner() {
         return this.server.isSingleplayerOwner(new NameAndId(this.playerProfile()));
     }
diff --git a/net/minecraft/server/network/ServerLoginPacketListenerImpl.java b/net/minecraft/server/network/ServerLoginPacketListenerImpl.java
index 07c6b9c2e849bd9d3014285619b256cc8a43771b..5b157a9a64a7c04369885acf1489b45d6b4e79da 100644
--- a/net/minecraft/server/network/ServerLoginPacketListenerImpl.java
+++ b/net/minecraft/server/network/ServerLoginPacketListenerImpl.java
@@ -129,6 +129,13 @@ public class ServerLoginPacketListenerImpl implements ServerLoginPacketListener,
         return this.requestedUsername != null ? this.requestedUsername + " (" + loggableAddress + ")" : loggableAddress;
     }
 
+    public @Nullable GameProfile fand$profile() {
+        if (this.authenticatedProfile != null) {
+            return this.authenticatedProfile;
+        }
+        return this.requestedUsername == null ? null : UUIDUtil.createOfflineProfile(this.requestedUsername);
+    }
+
     @Override
     public void handleHello(final ServerboundHelloPacket packet) {
         Validate.validState(this.state == ServerLoginPacketListenerImpl.State.HELLO, "Unexpected hello packet");
