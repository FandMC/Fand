+                            null),
                     "PlayerQuitEvent");
             var fandFinalQuitMessage = fandQuitEvent.message();
             if (fandFinalQuitMessage != null) {
@@ -376,6 +384,26 @@ public abstract class PlayerList {
         this.broadcastAll(new ClientboundPlayerInfoRemovePacket(List.of(player.getUUID())));
     }
 
+    private static io.fand.api.event.player.DisconnectReason fandDisconnectReason(final Component reason) {
+        String key = reason.getContents() instanceof TranslatableContents translatable
+                ? translatable.getKey()
+                : "";
+        return switch (key) {
+            case "disconnect.timeout" -> io.fand.api.event.player.DisconnectReason.TIMEOUT;
+            case "disconnect.endOfStream" -> io.fand.api.event.player.DisconnectReason.END_OF_STREAM;
+            case "multiplayer.disconnect.server_shutdown" -> io.fand.api.event.player.DisconnectReason.SERVER_SHUTDOWN;
+            case "multiplayer.disconnect.duplicate_login" -> io.fand.api.event.player.DisconnectReason.DUPLICATE_LOGIN;
+            case "multiplayer.disconnect.flying" -> io.fand.api.event.player.DisconnectReason.FLYING;
+            case "multiplayer.disconnect.idling" -> io.fand.api.event.player.DisconnectReason.IDLING;
+            case "multiplayer.disconnect.invalid_packet" -> io.fand.api.event.player.DisconnectReason.INVALID_PACKET;
+            case "multiplayer.disconnect.invalid_player_movement",
+                    "multiplayer.disconnect.invalid_vehicle_movement" -> io.fand.api.event.player.DisconnectReason.INVALID_MOVEMENT;
+            case "multiplayer.disconnect.chat_validation_failed" -> io.fand.api.event.player.DisconnectReason.CHAT_VALIDATION_FAILED;
+            case "disconnect.spam" -> io.fand.api.event.player.DisconnectReason.SPAM;
+            default -> io.fand.api.event.player.DisconnectReason.UNKNOWN;
+        };
+    }
+
     public io.fand.server.event.ServerEvents.LoginResult canPlayerLogin(final SocketAddress address, final GameProfile profile) {
         NameAndId nameAndId = new NameAndId(profile);
         Component reason;
