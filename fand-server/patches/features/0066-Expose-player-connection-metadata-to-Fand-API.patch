-    protected void save(final ServerPlayer player) {
+    public void save(final ServerPlayer player) {
         this.playerIo.save(player);
         ServerStatsCounter stats = this.stats.get(player.getUUID());
         if (stats != null) {
@@ -331,8 +333,14 @@ public abstract class PlayerList {
         ServerLevel level = player.level();
         var fandPlayerForQuit = io.fand.server.hooks.FandHooks.players().detach(player.getUUID()).orElse(null);
         if (fandPlayerForQuit != null) {
+            DisconnectionDetails details = player.connection.fand$disconnectionDetails();
+            Component disconnectMessage = details == null ? Component.empty() : details.reason();
             var fandQuitEvent = io.fand.server.hooks.FandHooks.fireOrLog(
-                    new io.fand.api.event.player.PlayerQuitEvent(fandPlayerForQuit, null),
+                    new io.fand.api.event.player.PlayerQuitEvent(
