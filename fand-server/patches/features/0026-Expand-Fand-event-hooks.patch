@@ -996,9 +996,15 @@ public class ServerLevel extends Level implements WorldGenLevel, ServerEntityGet
     }
 
     private boolean addEntity(final Entity entity) {
+        return this.addEntity(entity, io.fand.api.event.entity.EntitySpawnEvent.Cause.UNKNOWN);
+    }
+
+    private boolean addEntity(final Entity entity, final io.fand.api.event.entity.EntitySpawnEvent.Cause cause) {
         if (entity.isRemoved()) {
             LOGGER.warn("Tried to add entity {} but it was marked as removed already", entity.typeHolder().getRegisteredName());
             return false;
+        } else if (!io.fand.server.event.EntityEvents.fireSpawn(entity, cause)) {
+            return false;
         } else {
             return this.entityManager.addNewEntity(entity);
         }
