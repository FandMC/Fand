+            if (!io.fand.server.event.PlayerEvents.fireItemConsume(this, this.useItem.copy())) {
+                this.stopUsingItem();
+                return;
+            }
             this.connection.send(new ClientboundEntityEventPacket(this, EntityEvent.USE_ITEM_COMPLETE));
             super.completeUsingItem();
         }
@@ -1807,12 +1811,16 @@ public class ServerPlayer extends Player {
 
