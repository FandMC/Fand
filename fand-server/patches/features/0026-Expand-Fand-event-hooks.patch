@@ -3049,13 +3054,17 @@ public abstract class Entity
 
     public @Nullable Entity teleport(final TeleportTransition transition) {
         if (this.level() instanceof ServerLevel serverLevel && !this.isRemoved()) {
-            ServerLevel newLevel = transition.newLevel();
+            TeleportTransition fandTransition = io.fand.server.event.EntityEvents.fireTeleport(this, transition);
+            if (fandTransition == null) {
+                return null;
+            }
+            ServerLevel newLevel = fandTransition.newLevel();
             boolean otherDimension = newLevel.dimension() != serverLevel.dimension();
-            if (!transition.asPassenger()) {
+            if (!fandTransition.asPassenger()) {
                 this.stopRiding();
             }
 
-            return otherDimension ? this.teleportCrossDimension(serverLevel, newLevel, transition) : this.teleportSameDimension(serverLevel, transition);
+            return otherDimension ? this.teleportCrossDimension(serverLevel, newLevel, fandTransition) : this.teleportSameDimension(serverLevel, fandTransition);
         } else {
             return null;
         }
