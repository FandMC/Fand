+        private @Nullable PendingChunk firstAvailable(final IntSet lanesInExecution, final LongPredicate unavailableChunkPosition) {
+            for (int priority = 0; priority < ChunkTaskPriorityQueue.PRIORITY_LEVEL_COUNT; priority++) {
+                for (int lane = 0; lane < this.chunksByLaneAndPriority.length; lane++) {
+                    if (lanesInExecution.contains(lane)) {
+                        continue;
+                    }
+                    LongLinkedOpenHashSet chunks = this.chunksByLaneAndPriority[lane][priority];
+                    for (long chunkPos : chunks) {
+                        if (!unavailableChunkPosition.test(chunkPos)) {
+                            return new PendingChunk(chunkPos, priority);
+                        }
+                    }
+                }
+            }
+            return null;
+        }
+    }
