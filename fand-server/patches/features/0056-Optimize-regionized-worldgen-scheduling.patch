+        private LanePendingView(final RegionizedChunkTaskScheduler scheduler) {
+            this.scheduler = scheduler;
+            this.chunksByLaneAndPriority = new LongLinkedOpenHashSet[scheduler.laneCount()][ChunkTaskPriorityQueue.PRIORITY_LEVEL_COUNT];
+            for (int lane = 0; lane < this.chunksByLaneAndPriority.length; lane++) {
+                for (int priority = 0; priority < ChunkTaskPriorityQueue.PRIORITY_LEVEL_COUNT; priority++) {
+                    this.chunksByLaneAndPriority[lane][priority] = new LongLinkedOpenHashSet();
+                }
+            }
+        }
+
+        private void add(final long chunkPos, final int priority) {
+            this.chunksByLaneAndPriority[this.scheduler.laneIndex(chunkPos)][priority].add(chunkPos);
+        }
+
+        private void move(final long chunkPos, final int oldPriority, final int newPriority) {
+            this.remove(chunkPos, oldPriority);
+            this.add(chunkPos, newPriority);
+        }
+
+        private void remove(final long chunkPos) {
+            int lane = this.scheduler.laneIndex(chunkPos);
+            for (int priority = 0; priority < ChunkTaskPriorityQueue.PRIORITY_LEVEL_COUNT; priority++) {
+                this.chunksByLaneAndPriority[lane][priority].remove(chunkPos);
