index 0000000000000000000000000000000000000000..75f7e4f7cfb5e741885ac0cd3a0bae29eab5efeb
--- /dev/null
+++ b/net/minecraft/server/level/RegionizedChunkTaskScheduler.java
@@ -0,0 +1,68 @@
+package net.minecraft.server.level;
+
+import java.util.List;
+import java.util.Objects;
+import java.util.concurrent.CompletableFuture;
+import java.util.concurrent.ExecutorService;
+import java.util.concurrent.Executors;
+import net.minecraft.world.level.ChunkPos;
+
+final class RegionizedChunkTaskScheduler implements AutoCloseable {
+    static final int REGION_SIZE_CHUNKS = 8;
+
+    private final ExecutorService[] lanes;
+
+    RegionizedChunkTaskScheduler(final int laneCount, final String storageName) {
+        if (laneCount <= 0) {
+            throw new IllegalArgumentException("laneCount must be positive");
+        }
+        Objects.requireNonNull(storageName, "storageName");
+        this.lanes = new ExecutorService[laneCount];
+        for (int lane = 0; lane < laneCount; lane++) {
+            int laneId = lane + 1;
+            this.lanes[lane] = Executors.newSingleThreadExecutor(task -> {
+                Thread thread = new Thread(task, "Fand Worldgen - " + storageName + "-lane-" + laneId);
+                thread.setDaemon(true);
+                thread.setPriority(Math.max(Thread.MIN_PRIORITY, Thread.NORM_PRIORITY - 1));
+                return thread;
+            });
+        }
+    }
+
+    CompletableFuture<?> schedule(final long chunkPos, final List<Runnable> tasks) {
+        Objects.requireNonNull(tasks, "tasks");
+        return CompletableFuture.runAsync(() -> {
+            for (Runnable task : tasks) {
+                task.run();
+            }
+        }, this.lane(chunkPos));
+    }
+
+    private ExecutorService lane(final long chunkPos) {
+        return this.lanes[this.laneIndex(chunkPos)];
+    }
+
+    int laneIndex(final long chunkPos) {
+        return laneIndex(chunkPos, this.lanes.length);
+    }
+
+    int laneCount() {
+        return this.lanes.length;
+    }
+
+    static int laneIndex(final long chunkPos, final int laneCount) {
+        if (laneCount <= 0) {
+            throw new IllegalArgumentException("laneCount must be positive");
+        }
+        int regionX = Math.floorDiv(ChunkPos.getX(chunkPos), REGION_SIZE_CHUNKS);
+        int regionZ = Math.floorDiv(ChunkPos.getZ(chunkPos), REGION_SIZE_CHUNKS);
+        return Math.floorMod(31 * regionX + regionZ, laneCount);
+    }
+
+    @Override
+    public void close() {
+        for (ExecutorService lane : this.lanes) {
+            lane.shutdownNow();
+        }
+    }
+}
