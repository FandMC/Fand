@@ -349,7 +346,19 @@ public class Block extends BlockBehaviour implements ItemLike {
     }
 
     public static boolean isShapeFullBlock(final VoxelShape shape) {
-        return SHAPE_FULL_BLOCK_CACHE.getUnchecked(shape);
+        Object2ByteLinkedOpenHashMap<VoxelShape> cache = SHAPE_FULL_BLOCK_CACHE.get();
+        byte cached = cache.getAndMoveToFirst(shape);
+        if (cached != 127) {
+            return cached != 0;
+        }
+
+        boolean result = !Shapes.joinIsNotEmpty(Shapes.block(), shape, BooleanOp.NOT_SAME);
+        if (cache.size() == 256) {
+            cache.removeLastByte();
+        }
+
+        cache.putAndMoveToFirst(shape, (byte)(result ? 1 : 0));
+        return result;
     }
 
