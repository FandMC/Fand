Subject: [PATCH] Add event hooks for player and entity actions


diff --git a/net/minecraft/server/dedicated/DedicatedServer.java b/net/minecraft/server/dedicated/DedicatedServer.java
index 7e22ba953f78c74793b9b7f2dc5adb91e4ddc7c1..0500ef9fd787740f7baf5008274bdff6b8abe2c3 100644
--- a/net/minecraft/server/dedicated/DedicatedServer.java
+++ b/net/minecraft/server/dedicated/DedicatedServer.java
@@ -437,7 +437,8 @@ public class DedicatedServer extends MinecraftServer implements ServerInterface
     public void handleConsoleInputs() {
         while (!this.consoleInput.isEmpty()) {
             ConsoleInput input = this.consoleInput.remove(0);
-            this.getCommands().performPrefixedCommand(input.source, input.msg);
+            io.fand.server.command.CommandEvents.fireServerCommand(input.source, input.msg)
+                .ifPresent(command -> this.getCommands().performPrefixedCommand(input.source, command));
         }
     }
 
@@ -719,7 +720,11 @@ public class DedicatedServer extends MinecraftServer implements ServerInterface
     @Override
     public String runCommand(final String command) {
         this.rconConsoleSource.prepareForCommand();
-        this.executeBlocking(() -> this.getCommands().performPrefixedCommand(this.rconConsoleSource.createCommandSourceStack(), command));
+        this.executeBlocking(() -> {
+            var source = this.rconConsoleSource.createCommandSourceStack();
+            io.fand.server.command.CommandEvents.fireServerCommand(source, command)
+                .ifPresent(nextCommand -> this.getCommands().performPrefixedCommand(source, nextCommand));
+        });
         return this.rconConsoleSource.getCommandResponse();
     }
 
diff --git a/net/minecraft/server/network/ServerGamePacketListenerImpl.java b/net/minecraft/server/network/ServerGamePacketListenerImpl.java
index 804ba44c7544c83b57d43388e8dbff83cf4d85c5..644b1609eeff11fcac4d31f215481a363c6ac790 100644
--- a/net/minecraft/server/network/ServerGamePacketListenerImpl.java
+++ b/net/minecraft/server/network/ServerGamePacketListenerImpl.java
@@ -1912,6 +1912,9 @@ public class ServerGamePacketListenerImpl
     public void handleAnimate(final ServerboundSwingPacket packet) {
         PacketUtils.ensureRunningOnSameThread(packet, this, this.player.level());
         this.player.resetLastActionTime();
+        if (!io.fand.server.event.PlayerEvents.fireAnimation(this.player, packet.getHand())) {
+            return;
+        }
         this.player.swing(packet.getHand());
     }
 
@@ -2305,7 +2308,12 @@ public class ServerGamePacketListenerImpl
     @Override
     public void handlePlayerAbilities(final ServerboundPlayerAbilitiesPacket packet) {
         PacketUtils.ensureRunningOnSameThread(packet, this, this.player.level());
-        this.player.getAbilities().flying = packet.isFlying() && this.player.getAbilities().mayfly;
+        boolean flying = packet.isFlying() && this.player.getAbilities().mayfly;
+        if (this.player.getAbilities().flying != flying && !io.fand.server.event.PlayerEvents.fireToggleFlight(this.player, flying)) {
+            this.player.onUpdateAbilities();
+            return;
+        }
+        this.player.getAbilities().flying = flying;
     }
 
     @Override
