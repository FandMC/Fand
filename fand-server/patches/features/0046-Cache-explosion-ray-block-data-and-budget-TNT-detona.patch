From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: MC20018 <winme2001@outlook.com>
Date: Wed, 10 Jun 2026 21:37:40 +0800
Subject: [PATCH] Cache explosion ray block data and budget TNT detonations

Explosion rays revisit each block in the blast sphere ~5x; block state,
resistance, and bounds checks are now cached per position for the
duration of one explosion's ray pass (vanilla-equivalent: blocks only
mutate after all rays finish).

TNT detonations can be budgeted per level tick via fand.yml. Past-budget
TNT keeps its primed fuse and detonates on a following tick, spreading
mass detonations into a wave instead of one watchdog-tripping tick.
Budget 0 (default) preserves vanilla all-at-once behaviour.

diff --git a/net/minecraft/server/level/ServerLevel.java b/net/minecraft/server/level/ServerLevel.java
index ec387987121c563cc0487015fdb3d071658f32f9..307a4399cff17f3d14781df4a3675d5701cb5a86 100644
--- a/net/minecraft/server/level/ServerLevel.java
+++ b/net/minecraft/server/level/ServerLevel.java
@@ -222,11 +222,33 @@ public class ServerLevel extends Level implements WorldGenLevel, ServerEntityGet
     private final boolean tickTime;
     private final LevelDebugSynchronizers debugSynchronizers = new LevelDebugSynchronizers(this);
     private final io.fand.server.world.ExplosionDensityCache fandExplosionDensityCache = new io.fand.server.world.ExplosionDensityCache();
+    private final io.fand.server.world.ExplosionBlockCache fandExplosionBlockCache = new io.fand.server.world.ExplosionBlockCache();
+    private int fandTntDetonationsThisTick;
 
     public io.fand.server.world.ExplosionDensityCache fand$explosionDensityCache() {
         return this.fandExplosionDensityCache;
     }
 
+    public io.fand.server.world.ExplosionBlockCache fand$explosionBlockCache() {
+        return this.fandExplosionBlockCache;
+    }
+
+    /**
+     * Claims one slot of this tick's TNT detonation budget. Returns false when
+     * the budget is exhausted; callers keep the TNT primed and retry next tick.
+     */
+    public boolean fand$claimTntDetonation() {
+        int budget = io.fand.server.hooks.FandHooks.tntDetonationBudget();
+        if (budget <= 0) {
+            return true;
+        }
+        if (this.fandTntDetonationsThisTick >= budget) {
+            return false;
+        }
+        this.fandTntDetonationsThisTick++;
+        return true;
+    }
+
     public ServerLevel(
         final MinecraftServer server,
         final Executor executor,
@@ -360,6 +382,7 @@ public class ServerLevel extends Level implements WorldGenLevel, ServerEntityGet
         this.handlingTick = true;
         this.environmentAttributes().invalidateTickCache();
         this.fandExplosionDensityCache.clear();
+        this.fandTntDetonationsThisTick = 0;
         TickRateManager tickRateManager = this.tickRateManager();
         boolean runs = tickRateManager.runsNormally();
         if (runs) {
diff --git a/net/minecraft/world/entity/item/PrimedTnt.java b/net/minecraft/world/entity/item/PrimedTnt.java
index 69e10ce4d150e47da77d870917b25e1c744bf10b..a12a2501497f2cb4d33af02d536beec4b8bc3a0a 100644
--- a/net/minecraft/world/entity/item/PrimedTnt.java
+++ b/net/minecraft/world/entity/item/PrimedTnt.java
@@ -107,13 +107,20 @@ public class PrimedTnt extends Entity implements TraceableEntity {
         }
 
         int fuse = this.getFuse() - 1;
-        this.setFuse(fuse);
         if (fuse <= 0) {
+            // Fand: defer past-budget detonations to a later tick instead of
+            // detonating every fused TNT in the same tick. Fuse stays at its
+            // current value so the entity retries until it claims a slot.
+            if (this.level() instanceof ServerLevel fandLevel && !fandLevel.fand$claimTntDetonation()) {
+                return;
+            }
+            this.setFuse(fuse);
             this.discard();
             if (!this.level().isClientSide()) {
                 this.explode();
             }
         } else {
+            this.setFuse(fuse);
             this.updateFluidInteraction();
             if (this.level().isClientSide()) {
                 this.level().addParticle(ParticleTypes.SMOKE, this.getX(), this.getY() + 0.5, this.getZ(), 0.0, 0.0, 0.0);
